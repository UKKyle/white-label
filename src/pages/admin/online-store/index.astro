---
import AdminShell from '../../../components/admin/AdminShell.astro';
import { getAdminSession } from '../../../lib/adminAuth';
import { formatPrice } from '../../../lib/format';
import { getManagedImageSrc } from '../../../lib/imageStore';
import { productImageIdsBySlug } from '../../../lib/managedImages';
import { listOnlineStoreProducts, type OnlineStoreProduct } from '../../../lib/productStore';
import { getAdapterEnv } from '../../../lib/runtimeEnv';
import { routes } from '../../../lib/routes';
import '../../../styles/global.css';

export const prerender = false;

let session = null;

try {
  session = await getAdminSession(Astro);
} catch {
  session = null;
}

if (!session) {
  return Astro.redirect(routes.adminLogin);
}

const env = getAdapterEnv(Astro);
const query = (Astro.url.searchParams.get('q') ?? '').trim();
let products: OnlineStoreProduct[] = [];
let loadError = '';

try {
  products = await listOnlineStoreProducts(env);
} catch {
  loadError = 'Online store products could not be loaded. Check the Cloudflare KV binding before editing products.';
}

const productImages = Object.fromEntries(await Promise.all(
  products.map(async (product) => {
    const imageId = productImageIdsBySlug[product.slug];
    return [product.slug, imageId ? await getManagedImageSrc(env, imageId) : product.image];
  })
));

const normalizedQuery = query.toLowerCase();
const filteredProducts = normalizedQuery
  ? products.filter((product) => [
      product.name,
      product.slug,
      product.category,
      product.tagline,
      product.description,
      ...product.features,
    ].join(' ').toLowerCase().includes(normalizedQuery))
  : products;

const formatDate = (value?: string) => {
  if (!value) return 'Default content';

  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return 'Saved';

  return new Intl.DateTimeFormat('en-GB', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  }).format(date);
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Online Store | Admin Dashboard | Crumb Works</title>
  </head>

  <body class="font-body">
    <AdminShell
      activeNav="online-store"
      pageTitle="Online Store"
      pageSubtitle="Products shown on the website"
      searchAction={routes.adminOnlineStore}
      searchQuery={query}
      sessionEmail={session.email}
    >
      <Fragment slot="actions">
        <a
          href={routes.adminOnlineStoreNew}
          class="rounded-2xl bg-[#1d1d1d] px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-black"
        >
          Add product
        </a>
        <a
          href="/products"
          class="rounded-2xl border border-black/8 bg-white px-4 py-2.5 text-sm font-semibold text-[#202223] shadow-sm transition hover:bg-[#fafafa]"
        >
          View products
        </a>
      </Fragment>

      {loadError && (
        <div class="mb-4 rounded-[22px] border border-[#f0d18a] bg-[#fff8e8] px-5 py-4 text-sm font-medium text-[#7a4d00] shadow-[0_10px_30px_rgba(0,0,0,0.04)]">
          {loadError}
        </div>
      )}

      <section class="rounded-[26px] border border-black/6 bg-white shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
        <div class="border-b border-black/6 px-5 py-5 md:px-6">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <p class="text-sm font-semibold text-[#6d7175]">Website catalogue</p>
              <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#202223]">Manage live online store products</h2>
              <p class="mt-2 max-w-3xl text-sm leading-6 text-[#6d7175]">
                Edit the products already shown on the public shop. Changes are staged in each editor and only go live after saving.
              </p>
            </div>

            <form action={routes.adminOnlineStore} method="GET" class="w-full lg:max-w-md">
              <label class="flex items-center gap-3 rounded-[16px] border border-black/10 bg-[#f7f7f7] px-4 py-3 text-[#5d6166]">
                <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="11" cy="11" r="7"></circle>
                  <path d="m20 20-3.5-3.5"></path>
                </svg>
                <input
                  type="search"
                  name="q"
                  value={query}
                  placeholder="Search by product, slug, category, or keyword"
                  class="w-full bg-transparent text-sm text-[#202223] placeholder:text-[#8a9096] focus:outline-none"
                />
              </label>
            </form>
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-[900px] w-full border-collapse text-left text-sm">
            <thead class="bg-[#f7f7f7] text-xs font-bold uppercase tracking-[0.12em] text-[#6d7175]">
              <tr>
                <th class="px-5 py-3 md:px-6">Product</th>
                <th class="px-5 py-3">Status</th>
                <th class="px-5 py-3">Price</th>
                <th class="px-5 py-3">Category</th>
                <th class="px-5 py-3">Page path</th>
                <th class="px-5 py-3">Last updated</th>
                <th class="px-5 py-3 text-right">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-black/6">
              {filteredProducts.length === 0 ? (
                <tr>
                  <td colspan="7" class="px-5 py-8 text-center text-sm font-medium text-[#6d7175]">
                    No products match that search.
                  </td>
                </tr>
              ) : (
                filteredProducts.map((product) => (
                  <tr class="align-middle transition hover:bg-[#fbfbfb]">
                    <td class="px-5 py-4 md:px-6">
                      <div class="flex items-center gap-4">
                        <img
                          src={String(productImages[product.slug] ?? product.image)}
                          alt={product.imageAlt}
                          class="h-14 w-14 rounded-[12px] border border-black/8 bg-[#f7f7f7] object-cover"
                          loading="lazy"
                        />
                        <div>
                          <p class="font-semibold text-[#202223]">{product.name}</p>
                          <p class="mt-1 line-clamp-1 max-w-[320px] text-xs text-[#6d7175]">{product.tagline}</p>
                        </div>
                      </div>
                    </td>
                    <td class="px-5 py-4">
                      <div class="flex flex-wrap gap-2">
                        <span class="rounded-full bg-[#e8f5ef] px-3 py-1 text-xs font-semibold text-[#0f6b3f]">{product.status}</span>
                        {product.enquireOnly ? (
                          <span class="rounded-full bg-[#fff4e8] px-3 py-1 text-xs font-semibold text-[#8a4c00]">Enquire only</span>
                        ) : null}
                      </div>
                    </td>
                    <td class="px-5 py-4 font-semibold text-[#202223]">{formatPrice(product.price)}</td>
                    <td class="px-5 py-4 text-[#4c4f52]">{product.category}</td>
                    <td class="px-5 py-4 font-mono text-xs text-[#4c4f52]">{product.path}</td>
                    <td class="px-5 py-4 text-[#4c4f52]">{formatDate(product.updatedAt)}</td>
                    <td class="px-5 py-4 text-right">
                      <a href={routes.adminOnlineStoreProduct(product.slug)} class="inline-flex rounded-[12px] bg-[#1d1d1d] px-4 py-2 text-sm font-semibold text-white transition hover:bg-black">
                        Edit
                      </a>
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </section>
    </AdminShell>
  </body>
</html>
