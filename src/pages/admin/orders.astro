---
import AdminShell from '../../components/admin/AdminShell.astro';
import { createAdminCsrfToken, getAdminSession, isTrustedAdminOrigin, validateAdminCsrfToken } from '../../lib/adminAuth';
import { acceptOrderAndSendEmail } from '../../lib/orderEmails';
import { formatPrice } from '../../lib/format';
import {
  adminStatusTone,
  buildOrdersCsv,
  buildOrdersMetrics,
  filterOrders,
  formatFulfillmentLabel,
  formatOrderAdminStatusLabel,
  formatPaymentLabel,
  formatPaymentMethodLabel,
  formatSourceLabel,
  fulfillmentTone,
  manuallySetOrderFulfillmentStatus,
  paymentTone,
  sourceTone,
  syncOrdersWithSumUp,
  type OrdersFilter,
} from '../../lib/orderService';
import { listOrderRecords, orderItemCount, type OrderRecord } from '../../lib/orderStore';
import { getAdapterEnv } from '../../lib/runtimeEnv';
import { routes } from '../../lib/routes';
import '../../styles/global.css';

export const prerender = false;

const FILTER_LABELS: Record<OrdersFilter, string> = {
  all: 'All',
  online: 'Online',
  pos: 'POS',
  unfulfilled: 'Unfulfilled',
  unpaid: 'Unpaid',
  paid: 'Paid',
  open: 'Open',
  failed: 'Failed',
  expired: 'Expired',
  cancelled: 'Cancelled',
};

const selectedFilterParam = Astro.url.searchParams.get('filter')?.trim().toLowerCase() ?? 'all';
const selectedFilter = (Object.keys(FILTER_LABELS) as OrdersFilter[]).includes(selectedFilterParam as OrdersFilter)
  ? selectedFilterParam as OrdersFilter
  : 'all';
const searchQuery = Astro.url.searchParams.get('q')?.trim() ?? '';
const shouldRefresh = Astro.url.searchParams.get('sync') === '1';
const wantsCsv = Astro.url.searchParams.get('export') === 'csv';
const actionStatus = Astro.url.searchParams.get('status')?.trim() ?? '';

function buildOrdersQuery(params: Record<string, string | undefined>) {
  const next = new URLSearchParams();
  for (const [key, value] of Object.entries(params)) {
    if (value) next.set(key, value);
  }
  const query = next.toString();
  return `${routes.adminOrders}${query ? `?${query}` : ''}`;
}

let session = null;

try {
  session = await getAdminSession(Astro);
} catch {
  session = null;
}

if (!session) {
  return Astro.redirect(routes.adminLogin);
}

const env = getAdapterEnv(Astro);

if (Astro.request.method === 'POST') {
  if (!isTrustedAdminOrigin(Astro.request)) {
    return Astro.redirect(buildOrdersQuery({
      ...(selectedFilter !== 'all' ? { filter: selectedFilter } : {}),
      ...(searchQuery ? { q: searchQuery } : {}),
      status: 'csrf',
    }));
  }

  const formData = await Astro.request.formData();
  const csrfToken = String(formData.get('csrf') ?? '');
  const action = String(formData.get('action') ?? '').trim();
  const reference = String(formData.get('reference') ?? '').trim();

  const validCsrf = await validateAdminCsrfToken(Astro, session, csrfToken);

  if (!validCsrf) {
    return Astro.redirect(buildOrdersQuery({
      ...(selectedFilter !== 'all' ? { filter: selectedFilter } : {}),
      ...(searchQuery ? { q: searchQuery } : {}),
      status: 'csrf',
    }));
  }

  if (!reference) {
    return Astro.redirect(buildOrdersQuery({
      ...(selectedFilter !== 'all' ? { filter: selectedFilter } : {}),
      ...(searchQuery ? { q: searchQuery } : {}),
      status: 'invalid',
    }));
  }

  if (action === 'accept-order') {
    try {
      const result = await acceptOrderAndSendEmail(env, reference);

      return Astro.redirect(buildOrdersQuery({
        ...(selectedFilter !== 'all' ? { filter: selectedFilter } : {}),
        ...(searchQuery ? { q: searchQuery } : {}),
        status: result.error === 'missing' ? 'missing' : result.emailSent ? 'accepted' : 'accepted-email-failed',
      }));
    } catch {
      return Astro.redirect(buildOrdersQuery({
        ...(selectedFilter !== 'all' ? { filter: selectedFilter } : {}),
        ...(searchQuery ? { q: searchQuery } : {}),
        status: 'storage',
      }));
    }
  }

  const nextFulfillment = String(formData.get('fulfillmentStatus') ?? '').trim().toUpperCase();

  if (action !== 'toggle-fulfillment' || (nextFulfillment !== 'FULFILLED' && nextFulfillment !== 'UNFULFILLED')) {
    return Astro.redirect(buildOrdersQuery({
      ...(selectedFilter !== 'all' ? { filter: selectedFilter } : {}),
      ...(searchQuery ? { q: searchQuery } : {}),
      status: 'invalid',
    }));
  }

  let updatedOrder = null;

  try {
    updatedOrder = await manuallySetOrderFulfillmentStatus(env, reference, nextFulfillment as 'FULFILLED' | 'UNFULFILLED');
  } catch {
    return Astro.redirect(buildOrdersQuery({
      ...(selectedFilter !== 'all' ? { filter: selectedFilter } : {}),
      ...(searchQuery ? { q: searchQuery } : {}),
      status: 'storage',
    }));
  }

  return Astro.redirect(buildOrdersQuery({
    ...(selectedFilter !== 'all' ? { filter: selectedFilter } : {}),
    ...(searchQuery ? { q: searchQuery } : {}),
    status: updatedOrder ? (nextFulfillment === 'FULFILLED' ? 'fulfilled' : 'reopened') : 'missing',
  }));
}

let orders: OrderRecord[] = [];
let ordersLoadError = '';

try {
  orders = await listOrderRecords(env);
  orders = orders.length ? await syncOrdersWithSumUp(env, orders) : orders;
} catch {
  orders = [];
  ordersLoadError = 'Order storage could not be loaded. The Orders workspace is still available, but records may be incomplete until storage is reachable.';
}

const csrfToken = await createAdminCsrfToken(Astro, session);

if (shouldRefresh) {
  return Astro.redirect(routes.adminOrders);
}

const filteredOrders = filterOrders(orders, selectedFilter, searchQuery);

if (wantsCsv) {
  return new Response(buildOrdersCsv(filteredOrders), {
    status: 200,
    headers: {
      'Content-Type': 'text/csv; charset=utf-8',
      'Content-Disposition': `attachment; filename="crumb-works-orders-${new Date().toISOString().slice(0, 10)}.csv"`,
      'Cache-Control': 'no-store',
    },
  });
}

const now = Date.now();
const thirtyDaysAgo = now - 1000 * 60 * 60 * 24 * 30;
const windowedOrders = orders.filter((order) => new Date(order.createdAt).getTime() >= thirtyDaysAgo);
const metrics = buildOrdersMetrics(windowedOrders);
const hasActiveFilters = selectedFilter !== 'all' || Boolean(searchQuery);

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
});

function formatOrderDate(value: string) {
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? value : dateFormatter.format(date);
}

function buildFilterHref(filter: OrdersFilter) {
  return buildOrdersQuery({
    ...(filter !== 'all' ? { filter } : {}),
    ...(searchQuery ? { q: searchQuery } : {}),
  });
}

const bannerMessage = actionStatus === 'fulfilled'
  ? 'Order marked fulfilled.'
  : actionStatus === 'accepted'
    ? 'Order accepted and customer confirmation email sent.'
    : actionStatus === 'accepted-email-failed'
      ? 'Order accepted, but the customer confirmation email could not be sent. Please contact the customer manually.'
  : actionStatus === 'reopened'
    ? 'Order moved back to unfulfilled.'
    : actionStatus === 'missing'
      ? 'Order could not be found.'
      : actionStatus === 'invalid'
      ? 'That admin action was invalid.'
      : actionStatus === 'csrf'
        ? 'Your admin session could not verify that request. Please try again.'
        : actionStatus === 'storage'
          ? 'Order storage could not complete that admin action. Please try again after storage is reachable.'
          : '';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orders | Admin Dashboard | Crumb Works</title>
  </head>

  <body class="font-body">
    <AdminShell
      activeNav="orders"
      pageTitle="Orders: All locations"
      pageSubtitle="Orders"
      searchAction={routes.adminOrders}
      searchQuery={searchQuery}
      sessionEmail={session.email}
    >
      <Fragment slot="actions">
        <a
          href={`${routes.adminOrders}?${new URLSearchParams(searchQuery ? { q: searchQuery, sync: '1' } : { sync: '1' }).toString()}`}
          class="rounded-2xl border border-black/8 bg-white px-4 py-2.5 text-sm font-semibold text-[#202223] shadow-sm transition hover:bg-[#fafafa]"
        >
          Refresh
        </a>
        <a
          href={`${routes.adminOrders}?${new URLSearchParams({
            ...(selectedFilter !== 'all' ? { filter: selectedFilter } : {}),
            ...(searchQuery ? { q: searchQuery } : {}),
            export: 'csv',
          }).toString()}`}
          class="rounded-2xl border border-black/8 bg-white px-4 py-2.5 text-sm font-semibold text-[#202223] shadow-sm transition hover:bg-[#fafafa]"
        >
          Export
        </a>
      </Fragment>

      {bannerMessage && (
        <div class="mb-4 rounded-[22px] border border-black/8 bg-white px-5 py-4 text-sm font-medium text-[#202223] shadow-[0_10px_30px_rgba(0,0,0,0.04)]">
          {bannerMessage}
        </div>
      )}

      {ordersLoadError && (
        <div class="mb-4 rounded-[22px] border border-[#f0d18a] bg-[#fff8e8] px-5 py-4 text-sm font-medium text-[#7a4d00] shadow-[0_10px_30px_rgba(0,0,0,0.04)]">
          {ordersLoadError}
        </div>
      )}

      <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
        {[
          { label: 'Orders', value: String(metrics.orderCount) },
          { label: 'Ordered items', value: String(metrics.orderedItems) },
          { label: 'POS orders', value: String(metrics.posCount) },
          { label: 'Paid orders', value: String(metrics.paidCount) },
          { label: 'Revenue', value: formatPrice(metrics.grossSalesPence / 100) },
        ].map((card) => (
          <article class="rounded-[24px] border border-black/6 bg-white p-5 shadow-[0_12px_32px_rgba(0,0,0,0.04)]">
            <p class="text-sm font-medium text-[#5f6368]">{card.label}</p>
            <p class="mt-3 text-[2rem] font-semibold tracking-tight text-[#202223]">{card.value}</p>
            <p class="mt-2 text-sm text-[#7b8086]">Last 30 days</p>
          </article>
        ))}
      </section>

      <section class="mt-5 rounded-[26px] border border-black/6 bg-white shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
        <div class="border-b border-black/6 px-4 py-4 md:px-5">
          <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
            <div class="flex flex-wrap gap-2">
              {(Object.entries(FILTER_LABELS) as Array<[OrdersFilter, string]>).map(([filter, label]) => (
                <a
                  href={buildFilterHref(filter)}
                  class:list={[
                    'inline-flex h-11 items-center rounded-2xl px-4 text-sm font-semibold transition',
                    selectedFilter === filter
                      ? 'bg-[#f0f0f0] text-[#202223] shadow-[inset_0_0_0_1px_rgba(0,0,0,0.06)]'
                      : 'text-[#5f6368] hover:bg-[#f7f7f7] hover:text-[#202223]',
                  ]}
                >
                  {label}
                </a>
              ))}
            </div>

            <div class="flex flex-col gap-3 sm:flex-row">
              <form action={routes.adminOrders} method="GET" class="flex items-center gap-2 rounded-2xl border border-black/8 bg-[#fbfbfb] px-3 py-2.5">
                {selectedFilter !== 'all' && <input type="hidden" name="filter" value={selectedFilter} />}
                <svg viewBox="0 0 24 24" class="h-5 w-5 text-[#6d7175]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="11" cy="11" r="7"></circle>
                  <path d="m20 20-3.5-3.5"></path>
                </svg>
                <input
                  type="search"
                  name="q"
                  value={searchQuery}
                  placeholder="Search orders, customer, POS staff"
                  class="w-full min-w-[220px] bg-transparent text-sm text-[#202223] placeholder:text-[#8a9096] focus:outline-none"
                />
              </form>

              {hasActiveFilters && (
                <a href={routes.adminOrders} class="inline-flex h-11 items-center rounded-2xl border border-black/8 bg-[#fbfbfb] px-4 text-sm font-semibold text-[#5f6368] transition hover:bg-[#f3f3f3]">
                  Clear filters
                </a>
              )}
            </div>
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-full border-separate border-spacing-0 text-left">
            <thead>
              <tr class="text-sm text-[#6d7175]">
                <th class="border-b border-black/6 px-5 py-3 font-medium">Order</th>
                <th class="border-b border-black/6 px-5 py-3 font-medium">Date</th>
                <th class="border-b border-black/6 px-5 py-3 font-medium">Customer</th>
                <th class="border-b border-black/6 px-5 py-3 font-medium">Total</th>
                <th class="border-b border-black/6 px-5 py-3 font-medium">Payment</th>
                <th class="border-b border-black/6 px-5 py-3 font-medium">Status</th>
                <th class="border-b border-black/6 px-5 py-3 font-medium">Source</th>
                <th class="border-b border-black/6 px-5 py-3 font-medium">Items</th>
                <th class="border-b border-black/6 px-5 py-3 font-medium text-right">Action</th>
              </tr>
            </thead>
            <tbody>
              {filteredOrders.length === 0 ? (
                <tr>
                  <td colspan="9" class="px-5 py-12 text-center">
                    <p class="text-base font-semibold text-[#202223]">No orders matched this view.</p>
                    <p class="mt-2 text-sm text-[#6d7175]">POS syncs and SumUp checkouts will both appear here.</p>
                  </td>
                </tr>
              ) : (
                filteredOrders.map((order) => (
                  <tr class="align-top text-[15px] text-[#202223]">
                    <td class="border-b border-black/6 px-5 py-4">
                      <a href={routes.adminOrderDetail(order.reference)} class="font-semibold text-[#202223] transition hover:text-[#1256a1]">
                        #{order.orderNumber}
                      </a>
                      <p class="mt-1 text-xs uppercase tracking-[0.16em] text-[#8a9096]">{order.reference}</p>
                      {order.externalSourceId && <p class="mt-2 text-xs text-[#6d7175]">External: {order.externalSourceId}</p>}
                    </td>
                    <td class="border-b border-black/6 px-5 py-4 text-[#4c4f52]">{formatOrderDate(order.createdAt)}</td>
                    <td class="border-b border-black/6 px-5 py-4">
                      <p class="font-medium text-[#202223]">{order.customer.name || 'Walk-in customer'}</p>
                      <p class="mt-1 text-sm text-[#6d7175]">{order.customer.email || order.pos?.userName || 'No email captured'}</p>
                      {order.customer.phone && <p class="mt-1 text-sm text-[#6d7175]">{order.customer.phone}</p>}
                      <p class="mt-2 text-xs text-[#8a9096]">
                        Received email: {order.receivedEmailSentAt ? 'Sent' : 'Not sent'} · Accepted email: {order.acceptedEmailSentAt ? 'Sent' : 'Not sent'}
                      </p>
                    </td>
                    <td class="border-b border-black/6 px-5 py-4">
                      <p class="font-semibold text-[#202223]">{formatPrice(order.totalPence / 100)}</p>
                      <p class="mt-1 text-sm text-[#6d7175]">{formatPaymentMethodLabel(order.paymentMethod)}</p>
                    </td>
                    <td class="border-b border-black/6 px-5 py-4">
                      <span class:list={[
                        'inline-flex rounded-full px-3 py-1 text-sm font-semibold ring-1 ring-inset',
                        paymentTone(order.paymentStatus),
                      ]}>
                        {formatPaymentLabel(order.paymentStatus)}
                      </span>
                    </td>
                    <td class="border-b border-black/6 px-5 py-4">
                      <div class="flex flex-wrap gap-2">
                        <span class:list={[
                          'inline-flex rounded-full px-3 py-1 text-sm font-semibold ring-1 ring-inset',
                          fulfillmentTone(order.fulfillmentStatus),
                        ]}>
                          {formatFulfillmentLabel(order.fulfillmentStatus)}
                        </span>
                        <span class:list={[
                          'inline-flex rounded-full px-3 py-1 text-sm font-semibold ring-1 ring-inset',
                          adminStatusTone(order.orderStatus),
                        ]}>
                          {formatOrderAdminStatusLabel(order.orderStatus)}
                        </span>
                      </div>
                    </td>
                    <td class="border-b border-black/6 px-5 py-4">
                      <span class:list={[
                        'inline-flex rounded-full px-3 py-1 text-sm font-semibold ring-1 ring-inset',
                        sourceTone(order.source),
                      ]}>
                        {formatSourceLabel(order.source)}
                      </span>
                    </td>
                    <td class="border-b border-black/6 px-5 py-4 text-[#4c4f52]">
                      <p>{orderItemCount(order)} item{orderItemCount(order) === 1 ? '' : 's'}</p>
                      <p class="mt-1 text-sm text-[#6d7175]">{order.items.slice(0, 2).map((item) => item.name).join(', ')}</p>
                    </td>
                    <td class="border-b border-black/6 px-5 py-4 text-right">
                      <div class="flex justify-end gap-2">
                        <a
                          href={routes.adminOrderDetail(order.reference)}
                          class="inline-flex h-10 items-center rounded-2xl border border-black/8 bg-white px-3 text-sm font-semibold text-[#202223] transition hover:bg-[#f7f7f7]"
                        >
                          View
                        </a>
                        {!order.acceptedAt && order.orderStatus !== 'ACCEPTED' && order.orderStatus !== 'CANCELLED' && (
                          <form method="POST" class="inline-flex">
                            <input type="hidden" name="csrf" value={csrfToken} />
                            <input type="hidden" name="action" value="accept-order" />
                            <input type="hidden" name="reference" value={order.reference} />
                            <button type="submit" class="inline-flex h-10 items-center rounded-2xl border border-[#1256a1] bg-[#1256a1] px-3 text-sm font-semibold text-white transition hover:bg-[#0f4a8a]">
                              Accept order
                            </button>
                          </form>
                        )}
                        {order.fulfillmentStatus === 'FULFILLED' ? (
                          <form method="POST" class="inline-flex">
                            <input type="hidden" name="csrf" value={csrfToken} />
                            <input type="hidden" name="action" value="toggle-fulfillment" />
                            <input type="hidden" name="reference" value={order.reference} />
                            <input type="hidden" name="fulfillmentStatus" value="UNFULFILLED" />
                            <button type="submit" class="inline-flex h-10 items-center rounded-2xl border border-black/8 bg-white px-3 text-sm font-semibold text-[#202223] transition hover:bg-[#f7f7f7]">
                              Reopen
                            </button>
                          </form>
                        ) : (
                          <form method="POST" class="inline-flex">
                            <input type="hidden" name="csrf" value={csrfToken} />
                            <input type="hidden" name="action" value="toggle-fulfillment" />
                            <input type="hidden" name="reference" value={order.reference} />
                            <input type="hidden" name="fulfillmentStatus" value="FULFILLED" />
                            <button type="submit" class="inline-flex h-10 items-center rounded-2xl border border-[#121212] bg-[#1d1d1d] px-3 text-sm font-semibold text-white transition hover:bg-black">
                              Mark fulfilled
                            </button>
                          </form>
                        )}
                      </div>
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </section>
    </AdminShell>
  </body>
</html>
