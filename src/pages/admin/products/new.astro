---
import MerchantAdminLayout from '../../../layouts/MerchantAdminLayout.astro';
import Icon from '../../../components/platform/Icon.astro';
import { requireStoreMembership } from '../../../lib/platform/auth';
import { createCatalogProduct } from '../../../lib/storefront/catalogStore';
import { listStoreAssets } from '../../../lib/storefront/assetStore';
const value = await requireStoreMembership(Astro);
if (!value) return Astro.redirect('/login');
const { store, user, membership } = value;
let error = '';
if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const product = await createCatalogProduct(store.id, { name: String(form.get('name') ?? ''), slug: String(form.get('slug') ?? ''), description: String(form.get('description') ?? ''), price: String(form.get('price') ?? ''), inventory: String(form.get('inventory') ?? ''), category: String(form.get('category') ?? ''), status: String(form.get('status') ?? ''), imageAssetId: String(form.get('imageAssetId') ?? '') }, Astro);
    return Astro.redirect(`/admin/products/${product.id}`);
  } catch (caught) { error = caught instanceof Error ? caught.message : 'Product could not be created.'; }
}
const assets = await listStoreAssets(store.id, Astro);
---
<MerchantAdminLayout title={`Add product | ${store.name}`} store={store} user={user} membership={membership} heading="Add product" description="Create products for this store.">
  <a class="back-link" href="/admin/products"><Icon name="arrow-left" /> Products</a>
  {error && <p class="error" role="alert">{error}</p>}
  <form method="POST" class="record-editor">
    <section class="record-main">
      <div class="form-section"><h2>Product details</h2><label class="field">Name<input name="name" required autocomplete="off" /></label><label class="field">Description<textarea name="description" rows="6"></textarea></label></div>
      <div class="form-section"><h2>Pricing and inventory</h2><div class="form-grid"><label class="field">Price (£)<input name="price" type="number" min="0" step="0.01" required /></label><label class="field">Inventory<input name="inventory" type="number" min="0" step="1" value="0" /></label></div></div>
    </section>
    <aside class="record-aside">
      <div class="form-section"><h2>Publishing</h2><label class="field">Status<select name="status"><option value="draft">Draft</option><option value="active">Active</option></select></label><label class="field">Category<input name="category" /></label></div>
      <div class="form-section"><h2>Storefront</h2><label class="field">URL handle<input name="slug" required placeholder="product-name" pattern="[A-Za-z0-9 -]+" /></label><label class="field">Image<select name="imageAssetId"><option value="">No image</option>{assets.map((asset) => <option value={asset.id}>{asset.name}</option>)}</select><small>Upload reusable images from the builder Assets panel.</small></label></div>
      <button>Create product</button>
    </aside>
  </form>
</MerchantAdminLayout>
