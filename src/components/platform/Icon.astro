---
interface Props {
  name: string;
  size?: number;
  strokeWidth?: number;
  class?: string;
}

const { name, size = 18, strokeWidth = 1.8, class: className } = Astro.props;
---
<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {name === 'arrow-left' && <><path d="m15 18-6-6 6-6" /><path d="M9 12h10" /></>}
  {name === 'arrow-up' && <><path d="m18 15-6-6-6 6" /></>}
  {name === 'arrow-down' && <><path d="m6 9 6 6 6-6" /></>}
  {name === 'external-link' && <><path d="M15 3h6v6" /><path d="m10 14 11-11" /><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /></>}
  {name === 'monitor' && <><rect x="2" y="3" width="20" height="14" rx="2" /><path d="M8 21h8" /><path d="M12 17v4" /></>}
  {name === 'tablet' && <><rect x="5" y="2" width="14" height="20" rx="2" /><path d="M12 18h.01" /></>}
  {name === 'mobile' && <><rect x="7" y="2" width="10" height="20" rx="2" /><path d="M11 18h2" /></>}
  {name === 'undo' && <><path d="M9 14 4 9l5-5" /><path d="M4 9h10.5a5.5 5.5 0 0 1 0 11H11" /></>}
  {name === 'redo' && <><path d="m15 14 5-5-5-5" /><path d="M20 9H9.5a5.5 5.5 0 0 0 0 11H13" /></>}
  {name === 'copy' && <><rect x="9" y="9" width="12" height="12" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></>}
  {name === 'clipboard' && <><rect x="5" y="4" width="14" height="18" rx="2" /><path d="M9 4.5V3h6v1.5" /><path d="M9 12h6" /><path d="M9 16h4" /></>}
  {name === 'duplicate' && <><rect x="8" y="8" width="13" height="13" rx="2" /><path d="M16 8V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h3" /></>}
  {name === 'eye' && <><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12" /><circle cx="12" cy="12" r="3" /></>}
  {name === 'eye-off' && <><path d="m3 3 18 18" /><path d="M10.6 10.6a2 2 0 0 0 2.8 2.8" /><path d="M9.9 4.2A10 10 0 0 1 12 4c6.5 0 10 8 10 8a18 18 0 0 1-2 3.1" /><path d="M6.6 6.6A18.5 18.5 0 0 0 2 12s3.5 8 10 8a9.7 9.7 0 0 0 4.1-.9" /></>}
  {name === 'lock' && <><rect x="4" y="10" width="16" height="11" rx="2" /><path d="M8 10V7a4 4 0 0 1 8 0v3" /></>}
  {name === 'unlock' && <><rect x="4" y="10" width="16" height="11" rx="2" /><path d="M8 10V7a4 4 0 0 1 7.5-2" /></>}
  {name === 'trash' && <><path d="M3 6h18" /><path d="M8 6V4h8v2" /><path d="m19 6-1 15H6L5 6" /><path d="M10 11v5M14 11v5" /></>}
  {name === 'more' && <><circle cx="5" cy="12" r="1" fill="currentColor" stroke="none" /><circle cx="12" cy="12" r="1" fill="currentColor" stroke="none" /><circle cx="19" cy="12" r="1" fill="currentColor" stroke="none" /></>}
  {name === 'plus' && <><path d="M12 5v14M5 12h14" /></>}
  {name === 'search' && <><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></>}
  {name === 'image' && <><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="9" cy="9" r="2" /><path d="m21 15-5-5L5 21" /></>}
  {name === 'layout' && <><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 9h18M9 21V9" /></>}
  {name === 'type' && <><path d="M4 7V4h16v3M9 20h6M12 4v16" /></>}
  {name === 'grid' && <><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></>}
  {name === 'quote' && <><path d="M10 11H5a4 4 0 0 1 4-4" /><path d="M10 11v6H4v-6" /><path d="M21 11h-5a4 4 0 0 1 4-4" /><path d="M21 11v6h-6v-6" /></>}
  {name === 'mail' && <><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" /></>}
  {name === 'map-pin' && <><path d="M20 10c0 5-8 12-8 12S4 15 4 10a8 8 0 1 1 16 0" /><circle cx="12" cy="10" r="2" /></>}
  {name === 'clock' && <><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></>}
  {name === 'minus' && <><path d="M5 12h14" /></>}
  {name === 'help' && <><circle cx="12" cy="12" r="9" /><path d="M9.5 9a2.6 2.6 0 1 1 4 2.2c-1 .6-1.5 1.1-1.5 2.3" /><path d="M12 17h.01" /></>}
  {name === 'palette' && <><circle cx="13.5" cy="6.5" r=".5" fill="currentColor" /><circle cx="17.5" cy="10.5" r=".5" fill="currentColor" /><circle cx="8.5" cy="7.5" r=".5" fill="currentColor" /><circle cx="6.5" cy="12.5" r=".5" fill="currentColor" /><path d="M12 2a10 10 0 0 0 0 20c1.1 0 2-.9 2-2 0-.5-.2-.9-.5-1.3-.3-.4-.5-.8-.5-1.2a2 2 0 0 1 2-2h2.1A4.9 4.9 0 0 0 22 10.6C22 5.9 17.5 2 12 2Z" /></>}
  {name === 'chevron-right' && <path d="m9 18 6-6-6-6" />}
  {name === 'home' && <><path d="m3 11 9-8 9 8" /><path d="M5 10v10h14V10" /><path d="M9 20v-6h6v6" /></>}
  {name === 'users' && <><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.9M16 3.1a4 4 0 0 1 0 7.8" /></>}
  {name === 'settings' && <><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.9l.1.1-2.8 2.8-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.6v.2h-4V21a1.7 1.7 0 0 0-1-1.6 1.7 1.7 0 0 0-1.9.3l-.1.1L4.2 17l.1-.1a1.7 1.7 0 0 0 .3-1.9A1.7 1.7 0 0 0 3 14H2.8v-4H3a1.7 1.7 0 0 0 1.6-1 1.7 1.7 0 0 0-.3-1.9L4.2 7 7 4.2l.1.1A1.7 1.7 0 0 0 9 4.6 1.7 1.7 0 0 0 10 3V2.8h4V3a1.7 1.7 0 0 0 1 1.6 1.7 1.7 0 0 0 1.9-.3l.1-.1L19.8 7l-.1.1a1.7 1.7 0 0 0-.3 1.9 1.7 1.7 0 0 0 1.6 1h.2v4H21a1.7 1.7 0 0 0-1.6 1Z" /></>}
  {name === 'chart' && <><path d="M3 3v18h18" /><path d="m7 16 4-5 3 3 5-7" /></>}
  {name === 'card' && <><rect x="2" y="5" width="20" height="14" rx="2" /><path d="M2 10h20M6 15h2" /></>}
  {name === 'store' && <><path d="M3 9 5 3h14l2 6" /><path d="M5 13v8h14v-8" /><path d="M9 21v-6h6v6" /><path d="M3 9a3 3 0 0 0 6 0 3 3 0 0 0 6 0 3 3 0 0 0 6 0" /></>}
  {name === 'megaphone' && <><path d="m3 11 18-5v12L3 13v-2Z" /><path d="m11.6 15.4.8 4.6H7l-1-6" /></>}
  {name === 'log-out' && <><path d="M10 17l5-5-5-5M15 12H3" /><path d="M14 3h5a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-5" /></>}
  {name === 'check' && <path d="m5 12 4 4L19 6" />}
  {name === 'circle' && <circle cx="12" cy="12" r="8" />}
</svg>
