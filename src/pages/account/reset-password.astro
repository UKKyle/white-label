---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { resetCustomerPassword, validateAccountPassword } from '../../lib/customerAccountAuth';
import { getAdapterEnv } from '../../lib/runtimeEnv';
import { routes } from '../../lib/routes';
import { checkRateLimit, requestKey } from '../../security/rate-limit';

export const prerender = false;

let token = Astro.url.searchParams.get('token') ?? '';
let message = '';
let error = '';

if (Astro.request.method === 'POST') {
  if (!checkRateLimit(requestKey(Astro.request), 5, 60_000)) {
    error = 'Please wait a moment before trying again.';
  } else {
    const form = await Astro.request.formData();
    token = String(form.get('token') ?? '');
    const password = String(form.get('password') ?? '');
    const confirmPassword = String(form.get('confirmPassword') ?? '');
    const passwordError = validateAccountPassword(password);
    if (password !== confirmPassword || passwordError) {
      error = password !== confirmPassword ? 'Passwords do not match.' : passwordError;
    } else {
      const account = await resetCustomerPassword(getAdapterEnv(Astro), token, password);
      if (account) {
        message = 'Your password has been reset. Please sign in again.';
      } else {
        error = 'This reset link is invalid or has expired.';
      }
    }
  }
}
---

<Layout title="Reset Password | The Crumb Works" description="Choose a new account password.">
  <PageHero align="center" title="Reset Password" />
  <section class="warm-stage px-3 pb-18 pt-4 md:px-4">
    <div class="mx-auto max-w-xl">
      <form method="post" class="premium-form-card space-y-4">
        {message && <p class="rounded-[12px] border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">{message}</p>}
        {error && <p class="rounded-[12px] border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">{error}</p>}
        <input type="hidden" name="token" value={token} />
        <label class="premium-field"><span>New password</span><input class="input-shell" name="password" type="password" autocomplete="new-password" required /></label>
        <label class="premium-field"><span>Confirm new password</span><input class="input-shell" name="confirmPassword" type="password" autocomplete="new-password" required /></label>
        <button class="w-full rounded-[10px] bg-[var(--brand-ink)] px-6 py-3 text-sm font-semibold text-white" type="submit">Reset password</button>
        <p class="text-center text-sm"><a class="font-semibold text-[var(--brand-purple)]" href={routes.accountSignIn}>Back to sign in</a></p>
      </form>
    </div>
  </section>
</Layout>

