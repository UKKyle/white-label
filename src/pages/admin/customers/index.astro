---
import AdminShell from '../../../components/admin/AdminShell.astro';
import { getAdminSession } from '../../../lib/adminAuth';
import { listCustomerAccounts, syncAccountToCustomerRecord } from '../../../lib/customerAccountAuth';
import { backfillCustomersFromPaidOrders, listCustomerRecords, type CustomerRecord } from '../../../lib/customerStore';
import { formatPrice } from '../../../lib/format';
import { getAdapterEnv } from '../../../lib/runtimeEnv';
import { routes } from '../../../lib/routes';
import '../../../styles/global.css';

export const prerender = false;

type CustomerFilter = 'all' | 'opted-in' | 'not-opted-in';

let session = null;

try {
  session = await getAdminSession(Astro);
} catch {
  session = null;
}

if (!session) {
  return Astro.redirect(routes.adminLogin);
}

const FILTER_LABELS: Record<CustomerFilter, string> = {
  all: 'All',
  'opted-in': 'Marketing opted in',
  'not-opted-in': 'Not opted in',
};

const selectedFilterParam = Astro.url.searchParams.get('filter')?.trim() ?? 'all';
const selectedFilter = Object.keys(FILTER_LABELS).includes(selectedFilterParam)
  ? selectedFilterParam as CustomerFilter
  : 'all';
const searchQuery = Astro.url.searchParams.get('q')?.trim().toLowerCase() ?? '';
const env = getAdapterEnv(Astro);

let customers: CustomerRecord[] = [];
let loadError = '';

try {
  await backfillCustomersFromPaidOrders(env);
  for (const account of await listCustomerAccounts(env)) {
    await syncAccountToCustomerRecord(env, account);
  }
  customers = await listCustomerRecords(env);
} catch {
  customers = [];
  loadError = 'Customer records could not be loaded. Please check storage configuration and try again.';
}

const filteredCustomers = customers.filter((customer) => {
  if (selectedFilter === 'opted-in' && !customer.marketingOptIn) return false;
  if (selectedFilter === 'not-opted-in' && customer.marketingOptIn) return false;
  if (searchQuery && !`${customer.name ?? ''} ${customer.email} ${customer.phone ?? ''}`.toLowerCase().includes(searchQuery)) return false;
  return true;
}).sort((left, right) => (right.latestOrderAt ?? right.updatedAt).localeCompare(left.latestOrderAt ?? left.updatedAt));

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
});

function formatDate(value: string) {
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? value : dateFormatter.format(date);
}

function buildCustomersQuery(params: Record<string, string | undefined>) {
  const next = new URLSearchParams();
  for (const [key, value] of Object.entries(params)) {
    if (value) next.set(key, value);
  }
  const query = next.toString();
  return `${routes.adminCustomers}${query ? `?${query}` : ''}`;
}

---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customers | Crumb Works Admin</title>
  </head>
  <body class="font-body">
    <AdminShell
      activeNav="customers"
      pageTitle="Customers"
      pageSubtitle="Completed-order customers"
      searchAction={routes.adminCustomers}
      searchQuery={searchQuery}
      sessionEmail={session.email}
    >
      {loadError && (
        <div class="mb-4 rounded-[22px] border border-[#f0d18a] bg-[#fff8e8] px-5 py-4 text-sm font-medium text-[#7a4d00] shadow-[0_10px_30px_rgba(0,0,0,0.04)]">
          {loadError}
        </div>
      )}

      <div class="mb-4 flex flex-wrap gap-2">
        {(Object.keys(FILTER_LABELS) as CustomerFilter[]).map((filter) => (
          <a
            href={buildCustomersQuery({
              ...(filter !== 'all' ? { filter } : {}),
              ...(searchQuery ? { q: searchQuery } : {}),
            })}
            class:list={[
              'rounded-full border px-4 py-2 text-sm font-semibold transition',
              selectedFilter === filter
                ? 'border-[#1d1d1d] bg-[#1d1d1d] text-white'
                : 'border-black/8 bg-white text-[#4c4f52] hover:border-black/20',
            ]}
          >
            {FILTER_LABELS[filter]}
          </a>
        ))}
      </div>

      <section class="overflow-hidden rounded-[24px] border border-black/6 bg-white shadow-[0_12px_32px_rgba(0,0,0,0.04)]">
        <div class="border-b border-black/6 px-5 py-4">
          <p class="text-sm font-semibold text-[#202223]">{filteredCustomers.length} customer{filteredCustomers.length === 1 ? '' : 's'}</p>
        </div>

        {filteredCustomers.length ? (
          <div class="overflow-x-auto">
            <table class="min-w-full border-separate border-spacing-0 text-left text-sm">
              <thead class="bg-[#f7f7f7] text-xs uppercase tracking-[0.12em] text-[#6d7175]">
                <tr>
                  <th class="px-5 py-3 font-semibold">Name</th>
                  <th class="px-5 py-3 font-semibold">Email</th>
                  <th class="px-5 py-3 font-semibold">Phone</th>
                  <th class="px-5 py-3 font-semibold">Total orders</th>
                  <th class="px-5 py-3 font-semibold">Total spend</th>
                  <th class="px-5 py-3 font-semibold">Last order</th>
                  <th class="px-5 py-3 font-semibold">Marketing status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-black/6">
                {filteredCustomers.map((customer) => {
                  return (
                    <tr class="transition hover:bg-[#fafafa]">
                      <td class="px-5 py-4">
                        <a href={routes.adminCustomerDetail(customer.email)} class="block max-w-48 truncate font-semibold text-[#202223] hover:underline">{customer.name || 'Unnamed customer'}</a>
                      </td>
                      <td class="px-5 py-4">
                        <a href={routes.adminCustomerDetail(customer.email)} class="block max-w-56 truncate text-[#4c4f52] hover:underline">{customer.email}</a>
                      </td>
                      <td class="px-5 py-4 text-[#4c4f52]">{customer.phone || '—'}</td>
                      <td class="px-5 py-4 text-[#4c4f52]">{customer.totalOrders}</td>
                      <td class="px-5 py-4 text-[#4c4f52]">{formatPrice(customer.totalSpentPence / 100)}</td>
                      <td class="px-5 py-4 text-[#4c4f52]">{customer.latestOrderAt ? formatDate(customer.latestOrderAt) : '—'}</td>
                      <td class="px-5 py-4">
                        <span class:list={[
                          'inline-flex rounded-full px-3 py-1 text-xs font-semibold',
                          customer.marketingOptIn ? 'bg-[#e7f7ed] text-[#0f6b2f]' : 'bg-[#f1f1f1] text-[#5f6368]',
                        ]}>
                          {customer.marketingOptIn ? '✅ Opted In' : '❌ Not Opted In'}
                        </span>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="px-5 py-12 text-center">
            <p class="text-base font-semibold text-[#202223]">No customers found</p>
            <p class="mt-2 text-sm text-[#6d7175]">Customers appear after a payment has been confirmed.</p>
          </div>
        )}
      </section>
    </AdminShell>
  </body>
</html>
