---
import PlatformLayout from '../../layouts/PlatformLayout.astro'; import { requirePlatformOwner } from '../../lib/platform/auth'; import { listStores } from '../../lib/platform/store';
const owner=await requirePlatformOwner(Astro); if(!owner)return Astro.redirect('/owner/login'); const stores=await listStores(Astro); const active=stores.filter(s=>s.status==='active'||s.status==='trial').length; const suspended=stores.filter(s=>s.status==='suspended').length;
---
<PlatformLayout title="Platform overview | White Label"><div class="shell"><nav class="nav"><strong>WHITE LABEL</strong><a href="/owner">Overview</a><a href="/owner/stores">Stores</a><a href="/owner/stores/new">Create store</a><a href="/admin/logout">Sign out</a></nav><main class="main stack"><div class="split"><div><div class="brand">Platform owner</div><h1>Overview</h1></div><span class="status">Protected</span></div><section class="grid"><div class="card"><div class="muted">Total stores</div><div class="metric">{stores.length}</div></div><div class="card"><div class="muted">Active or trial</div><div class="metric">{active}</div></div><div class="card"><div class="muted">Suspended</div><div class="metric">{suspended}</div></div></section><section class="card"><h2>Platform activity</h2><p class="muted">No fabricated analytics are displayed. Store activity and audit history appear as merchants begin using the platform.</p></section></main></div></PlatformLayout>
