---
import MerchantAdminLayout from '../../layouts/MerchantAdminLayout.astro';
import { requireStoreMembership } from '../../lib/platform/auth';
const value = await requireStoreMembership(Astro);
if (!value) return Astro.redirect('/login');
const { store, user, membership } = value;
---
<MerchantAdminLayout title={`Set up ${store.name} | White Label`} store={store} user={user} membership={membership} heading="Set up your store" description="Start with the essentials. Each action stays inside the merchant dashboard.">
  <section class="grid">
    <a class="card" href="/admin/settings/store" style="text-decoration:none"><h2>Store details</h2><p class="muted">Review business identity and contact details.</p></a>
    <a class="card" href="/admin/products" style="text-decoration:none"><h2>Products</h2><p class="muted">Prepare the tenant catalogue workspace.</p></a>
    <a class="card" href="/admin/online-store/branding" style="text-decoration:none"><h2>Branding</h2><p class="muted">Configure the storefront look and feel.</p></a>
    <a class="card" href="/admin/settings/fulfilment" style="text-decoration:none"><h2>Fulfilment</h2><p class="muted">Plan delivery, collection or dispatch.</p></a>
  </section>
  <section class="card" style="margin-top:16px"><a class="button" href="/admin">Open dashboard</a></section>
</MerchantAdminLayout>
