---
import PlatformLayout from '../../layouts/PlatformLayout.astro'; import { requireStoreMembership } from '../../lib/platform/auth';
const value=await requireStoreMembership(Astro); if(!value)return Astro.redirect('/login');
---
<PlatformLayout title="Set up your store | White Label"><div class="shell"><nav class="nav"><strong>{value.store.name}</strong><a href="/admin">Home</a><a href="/admin/onboarding">Set up</a><a href="/admin/logout">Sign out</a></nav><main class="main stack"><div><div class="brand">Store setup</div><h1>Your blank workspace is ready</h1><p class="muted">White Label has not added demo products, pages, customers, or orders to your store.</p></div><section class="card stack"><a class="button secondary" href="/admin/settings">Add business details</a><a class="button secondary" href="/admin/products">Add your first product</a><a class="button secondary" href="/admin/online-store">Configure online store</a><a class="button" href="/admin">Open dashboard</a></section></main></div></PlatformLayout>
