---
import MerchantAdminLayout from '../../layouts/MerchantAdminLayout.astro';
import Subnav from '../../components/platform/Subnav.astro';
import { requireStoreMembership } from '../../lib/platform/auth';
import { merchantSettingsNavigation } from '../../lib/platform/navigation';
const value = await requireStoreMembership(Astro);
if (!value) return Astro.redirect('/login');
const { store, user, membership } = value;
---
<MerchantAdminLayout title={`Settings | ${store.name}`} store={store} user={user} membership={membership} heading="Settings" description="Store configuration areas for this merchant workspace.">
  <Subnav items={merchantSettingsNavigation} />
  <section class="grid">
    {merchantSettingsNavigation.filter((item) => item.href !== '/admin/settings').map((item) => (
      <a class="card" href={item.href} style="text-decoration:none">
        <h2>{item.label}</h2>
        <p class="muted">{item.description ?? 'Open settings section'}</p>
      </a>
    ))}
  </section>
</MerchantAdminLayout>
