---
import MerchantAdminLayout from '../../layouts/MerchantAdminLayout.astro';
import { requireStoreMembership } from '../../lib/platform/auth';

const value = await requireStoreMembership(Astro);
if (!value) return Astro.redirect('/login');
const { store, user, membership } = value;
const checklist = [
  ['Add business details', Boolean(store.contactEmail && store.contactPhone)],
  ['Choose and customise a storefront template', false],
  ['Add the first product', false],
  ['Configure fulfilment', false],
  ['Review policies', false],
  ['Preview and publish', false],
];
const completed = checklist.filter(([, done]) => done).length;
---
<MerchantAdminLayout title={`Home | ${store.name}`} store={store} user={user} membership={membership} heading={store.name} description="Your store workspace shows only data owned by this store.">
  <section class="grid">
    <div class="card"><p class="muted">Store status</p><p class="metric">{store.status.replaceAll('_', ' ')}</p></div>
    <div class="card"><p class="muted">Billing</p><p class="metric">{store.billingStatus.replaceAll('_', ' ')}</p></div>
    <div class="card"><p class="muted">Setup progress</p><p class="metric">{completed}/{checklist.length}</p></div>
    <div class="card"><p class="muted">Recent orders</p><p class="metric">0</p></div>
  </section>
  <section class="two-col" style="margin-top:16px">
    <div class="card">
      <h2>Next actions</h2>
      <p class="muted">These links stay inside the merchant admin and lead to the new platform routes.</p>
      <div class="grid">
        <a class="button secondary" href="/admin/products">Add products</a>
        <a class="button secondary" href="/admin/online-store/branding">Set branding</a>
        <a class="button secondary" href="/admin/settings/fulfilment">Configure fulfilment</a>
        <a class="button" href="/admin/online-store">Open online store hub</a>
      </div>
    </div>
    <div class="card">
      <h2>Setup checklist</h2>
      <ul class="checklist">
        {checklist.map(([label, done]) => <li><span class:list={['dot', done && 'done']}></span>{label}</li>)}
      </ul>
    </div>
  </section>
  <section class="card" style="margin-top:16px">
    <h2>Recent activity</h2>
    <p class="muted">No store-scoped activity has been recorded yet.</p>
  </section>
</MerchantAdminLayout>
