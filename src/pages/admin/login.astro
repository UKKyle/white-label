---
import {
  authenticateAdminLogin,
  buildAdminSessionCookie,
  isTrustedAdminOrigin,
} from '../../lib/adminAuth';
import { routes } from '../../lib/routes';
import '../../styles/global.css';

export const prerender = false;

const loginErrorRedirect = `${routes.adminLogin}?error=1`;
const loginUnavailableRedirect = `${routes.adminLogin}?error=config`;
const loginCsrfRedirect = `${routes.adminLogin}?error=csrf`;
const loginSessionRedirect = `${routes.adminLogin}?error=session`;

const url = new URL(Astro.request.url);
const errorCode = url.searchParams.get('error');

let error = errorCode === '1'
  ? 'Invalid admin login.'
  : errorCode === 'config'
    ? 'Login unavailable. Please check admin configuration.'
    : errorCode === 'config-session'
      ? 'Login unavailable. Admin session secret is missing or too short.'
      : errorCode === 'config-password'
        ? 'Login unavailable. Admin password secret is missing.'
        : errorCode === 'config-totp'
          ? 'Login unavailable. Admin 2FA secret is missing.'
          : errorCode === 'config-identity'
            ? 'Login unavailable. Admin email allowlist is missing.'
            : errorCode === 'csrf'
              ? 'Login request could not be verified. Please try again.'
              : errorCode === 'session'
                ? 'Login session could not be created. Please try again.'
                : '';

if (Astro.request.method === 'POST') {
  try {
    if (!isTrustedAdminOrigin(Astro.request)) {
      console.warn('admin_login_csrf_failure', { reason: 'untrusted_origin' });

      return new Response(null, {
        status: 303,
        headers: {
          Location: loginCsrfRedirect,
        },
      });
    }

    const formData = await Astro.request.formData();
    const email = String(formData.get('email') ?? '');
    const password = String(formData.get('password') ?? '');
    const totp = String(formData.get('totp') ?? '');

    const loginResult = await authenticateAdminLogin(email, password, totp, Astro);

    if (loginResult.ok) {
      let sessionCookie = '';

      try {
        sessionCookie = await buildAdminSessionCookie(email, Astro);
      } catch (error) {
        console.warn('admin_login_session_write_failure', {
          message: error instanceof Error ? error.message : 'Unknown admin session error',
        });

        return new Response(null, {
          status: 303,
          headers: {
            Location: loginSessionRedirect,
          },
        });
      }

      return new Response(null, {
        status: 303,
        headers: {
          Location: routes.adminDashboard,
          'Set-Cookie': sessionCookie,
        },
      });
    }

    if (loginResult.reason === 'missing_config') {
      const configRedirect = loginResult.configCode
        ? `${routes.adminLogin}?error=config-${loginResult.configCode}`
        : loginUnavailableRedirect;

      return new Response(null, {
        status: 303,
        headers: {
          Location: configRedirect,
        },
      });
    }

    return new Response(null, {
      status: 303,
      headers: {
        Location: loginErrorRedirect,
      },
    });
  } catch (error) {
    console.warn('admin_login_request_failure', {
      message: error instanceof Error ? error.message : 'Unknown admin login error',
    });

    return new Response(null, {
      status: 303,
      headers: {
        Location: loginUnavailableRedirect,
      },
    });
  }
}

if (Astro.request.method !== 'GET' && Astro.request.method !== 'POST') {
  return new Response('Method not allowed', {
    status: 405,
    headers: {
      Allow: 'GET, POST',
    },
  });
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login | Crumb Works</title>
  </head>
  <body class="font-body min-h-screen bg-[#f7f7fb] text-[#17123b]">
    <main class="flex min-h-screen items-center justify-center px-5 py-8">
      <section class="w-full max-w-[560px] rounded-[30px] border border-[#d9c8ff] bg-white px-8 py-9 shadow-[0_18px_50px_rgba(60,25,130,0.08)] sm:px-12 sm:py-10">
        <div class="text-center">
          <svg viewBox="0 0 64 64" class="mx-auto h-12 w-12 text-black" fill="currentColor" aria-hidden="true">
            <path d="M31.2 7.1c3.2 0 5.6 2.3 5.6 5.3 0 2.7-1.9 4.7-4.7 5.1-.4.1-.8.4-.8.8 0 .5.4.8.9.8 6.9.2 12.4 5.2 12.4 11.7 0 1.3-.2 2.6-.7 3.8h2.2c3.7 0 6.6 3 6.6 6.6 0 3.4-2.6 6.3-6 6.6l-3.4 10.6c-.5 1.5-1.9 2.5-3.5 2.5H23.7c-1.6 0-3-1-3.5-2.5l-3.4-10.6c-3.4-.3-6-3.2-6-6.6 0-3.7 3-6.6 6.6-6.6h2.2c-.4-1.2-.7-2.5-.7-3.8 0-6.4 5.5-11.5 12.4-11.7 1.9-.1 3.4-1.5 3.4-3.3 0-1.9-1.5-3.3-3.5-3.3-1.2 0-2.3.6-2.9 1.5-.7 1-2.1 1.3-3.1.6-1-.7-1.3-2.1-.6-3.1 1.5-2.7 4-4.4 6.6-4.4Zm-9.6 31.8h-4.2c-1.3 0-2.3 1-2.3 2.3 0 1.3 1 2.3 2.3 2.3h29.2c1.3 0 2.3-1 2.3-2.3 0-1.3-1-2.3-2.3-2.3h-4.2c-1 1.1-2.4 1.8-4 1.8-1.8 0-3.4-.9-4.4-2.2-1 1.3-2.6 2.2-4.4 2.2-1.7 0-3.3-.8-4.3-2.1-1 1.3-2.6 2.1-4.3 2.1-1.5 0-2.9-.7-3.9-1.8Zm2.2 8.9 2.7 8.6h3.3l-1.4-8.6h-4.6Zm8.9 0 1.4 8.6h3.4l2.7-8.6h-7.5Zm-9.6-17c0 1.7 1.3 3 3 3 .9 0 1.7-.4 2.3-1.1.5-.6 1.3-1 2.1-1s1.6.4 2.1 1c.6.7 1.4 1.1 2.3 1.1s1.7-.4 2.3-1.1c.5-.6 1.3-1 2.1-1 .7 0 1.4.3 1.9.8.3-.6.5-1.2.5-1.8 0-4-4.1-7.3-9.4-7.3s-9.2 3.4-9.2 7.4Z"></path>
          </svg>
          <p class="mt-5 text-[1.55rem] font-black uppercase leading-none tracking-[0.08em] text-[#5518d4] sm:text-[1.85rem]">Crumb Works</p>
          <h1 class="mt-4 text-[2rem] font-bold leading-tight tracking-tight text-[#17123b] sm:text-[2.3rem]">Management login</h1>
        </div>

      {error && (
          <p class="mt-6 rounded-[18px] border border-[#f2b8b5] bg-[#fff0f0] px-4 py-3 text-sm font-semibold text-[#a12018]" role="alert">{error}</p>
      )}

        <form method="POST" action={routes.adminLogin} class="mt-8 space-y-5">
        <div class="space-y-3">
          <label for="email" class="block text-lg font-medium text-[#514587]">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="username"
            required
              class="h-14 w-full rounded-[10px] border border-[#d7c7ff] bg-white px-4 text-lg text-[#17123b] outline-none transition focus:border-[#5518d4] focus:ring-4 focus:ring-[#5518d4]/10"
          />
        </div>

        <div class="space-y-3">
          <label for="password" class="block text-lg font-medium text-[#514587]">Access code</label>
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            required
              class="h-14 w-full rounded-[10px] border border-[#d7c7ff] bg-white px-4 text-lg text-[#17123b] outline-none transition focus:border-[#5518d4] focus:ring-4 focus:ring-[#5518d4]/10"
          />
        </div>

        <div class="space-y-3">
          <label for="totp" class="block text-lg font-medium text-[#514587]">Authenticator code</label>
          <input
            id="totp"
            name="totp"
            type="text"
            inputmode="numeric"
            autocomplete="one-time-code"
            pattern="[0-9 ]{6,8}"
            maxlength="8"
            required
              class="h-14 w-full rounded-[10px] border border-[#d7c7ff] bg-white px-4 text-lg tracking-[0.22em] text-[#17123b] outline-none transition focus:border-[#5518d4] focus:ring-4 focus:ring-[#5518d4]/10"
          />
        </div>

        <button
          type="submit"
            class="h-14 w-full rounded-[11px] bg-[#5518d4] px-6 text-lg font-bold text-white transition hover:bg-[#4510b8] focus:outline-none focus:ring-4 focus:ring-[#5518d4]/20"
        >
          Sign in
        </button>
      </form>
      </section>
    </main>
  </body>
</html>
