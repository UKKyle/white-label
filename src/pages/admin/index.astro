---
import PlatformLayout from '../../layouts/PlatformLayout.astro'; import { requireStoreMembership } from '../../lib/platform/auth';
const value=await requireStoreMembership(Astro); if(!value)return Astro.redirect('/login'); const {store}=value;
---
<PlatformLayout title={`Admin | ${store.name}`}><div class="shell"><nav class="nav"><strong>{store.name}</strong><a href="/admin">Home</a><a href="/admin/orders">Orders</a><a href="/admin/products">Products</a><a href="/admin/customers">Customers</a><a href="/admin/online-store">Online Store</a><a href="/admin/pos">POS</a><a href="/admin/settings">Settings</a><a href="/admin/logout">Sign out</a></nav><main class="main stack"><div><div class="brand">Merchant workspace</div><h1>{store.name}</h1><p class="muted">Your private operational workspace is ready for setup.</p></div><section class="grid"><div class="card"><div class="muted">Store status</div><div class="metric">{store.status}</div></div><div class="card"><div class="muted">Billing</div><div class="metric">{store.billingStatus}</div></div></section><section class="card"><h2>Complete your store setup</h2><div class="stack muted"><span>○ Add your first product</span><span>○ Configure business details</span><span>○ Set fulfilment options</span><span>○ Add branding</span><span>○ Configure payments and POS</span><span>○ Preview and publish when ready</span></div></section></main></div></PlatformLayout>
