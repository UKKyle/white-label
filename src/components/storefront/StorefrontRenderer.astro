---
import type { Store } from '../../types/platform';
import type { DeviceMode, PageConfiguration, SectionInstance, ThemeConfiguration } from '../../types/storefront';
import { resolveStorefrontHref } from '../../lib/storefront/links';
import { listCatalogProducts } from '../../lib/storefront/catalogStore';

const { store, configuration, pageId = 'home', preview = false, selectedSectionId, editor = false, device = 'desktop' } = Astro.props as {
  store: Store;
  configuration: ThemeConfiguration;
  pageId?: string;
  preview?: boolean;
  selectedSectionId?: string;
  editor?: boolean;
  device?: DeviceMode;
};
const page: PageConfiguration = configuration.pages[pageId] ?? configuration.pages.home;
const settings = configuration.globalSettings;
const sections = [...page.sections].filter((section) => section.visible).sort((a, b) => a.order - b.order);
const headerSection = sections.find((section) => section.type === 'header');
const footerSection = sections.find((section) => section.type === 'footer');
const contentSections = sections.filter((section) => !['header', 'footer'].includes(section.type));
const nav = [...configuration.navigation.mainMenu].filter((item) => item.visible).sort((a, b) => a.order - b.order);
const footer = [...configuration.navigation.footerMenu].filter((item) => item.visible).sort((a, b) => a.order - b.order);
const homeHref = `/store/${encodeURIComponent(store.slug)}`;
const link = (value: unknown) => resolveStorefrontHref(store.slug, value);
const catalogue = (await listCatalogProducts(store.id, Astro)).filter((product) => product.status === 'active');
const assetHref = (assetId?: string) => assetId ? `/store-assets/${encodeURIComponent(store.slug)}/${encodeURIComponent(assetId)}` : '';
const editable = (field: string, type = 'text', elementId = field) => editor ? {
  'data-editor-field': field,
  'data-editor-type': type,
  'data-editor-element-id': elementId,
  tabindex: '0',
} : {};
const sectionStyle = (section: SectionInstance) => [
  `--section-background:${String(section.settings.backgroundColor || 'transparent')}`,
  `--section-text:${String(section.settings.textColor || settings.textColor)}`,
  `--section-padding-top:${Number(section.settings.paddingTop ?? settings.sectionSpacing)}px`,
  `--section-padding-bottom:${Number(section.settings.paddingBottom ?? settings.sectionSpacing)}px`,
  `--section-padding-top-tablet:${Number(section.settings.paddingTopTablet ?? section.settings.paddingTop ?? settings.sectionSpacing)}px`,
  `--section-padding-bottom-tablet:${Number(section.settings.paddingBottomTablet ?? section.settings.paddingBottom ?? settings.sectionSpacing)}px`,
  `--section-padding-top-mobile:${Number(section.settings.paddingTopMobile ?? section.settings.paddingTop ?? settings.sectionSpacing)}px`,
  `--section-padding-bottom-mobile:${Number(section.settings.paddingBottomMobile ?? section.settings.paddingBottom ?? settings.sectionSpacing)}px`,
  `--section-horizontal-padding:${Number(section.settings.paddingHorizontal ?? 18)}px`,
  `--section-align:${String(section.settings.alignment || 'left')}`,
  `--section-align-tablet:${String(section.settings.alignmentTablet || section.settings.alignment || 'left')}`,
  `--section-align-mobile:${String(section.settings.alignmentMobile || section.settings.alignment || 'left')}`,
  `--section-image-fit:${String(section.settings.imageFit || 'cover')}`,
  `--section-focal-point:${String(section.settings.focalPoint || 'center')}`,
  `--section-image-zoom:${Number(section.settings.imageZoom ?? 100) / 100}`,
  `--section-image-radius:${Number(section.settings.imageRadius ?? settings.cardRadius)}px`,
  `--section-image-aspect:${String(section.settings.imageAspect || 'auto')}`,
  `--section-media-width:${Number(section.settings.mediaWidth ?? 45)}%`,
  `--section-grid-columns:${Number(section.settings.columnsDesktop ?? 4)}`,
  `--section-grid-columns-tablet:${Number(section.settings.columnsTablet ?? Math.min(3, Number(section.settings.columnsDesktop ?? 4)))}`,
  `--section-grid-columns-mobile:${Number(section.settings.columnsMobile ?? 1)}`,
  `--section-grid-gap:${Number(section.settings.gridGap ?? 16)}px`,
].join(';');
---
<div
  class:list={['storefront', `template-${configuration.templateKey}`, `product-card-${settings.productCardStyle}`, preview && 'is-preview', editor && 'is-editor-canvas', editor && `editor-device-${device}`]}
  data-editor-page-id={editor ? pageId : undefined}
  style={`--sf-primary:${settings.primaryColor};--sf-secondary:${settings.secondaryColor};--sf-accent:${settings.accentColor};--sf-bg:${settings.backgroundColor};--sf-surface:${settings.surfaceColor};--sf-text:${settings.textColor};--sf-muted:${settings.mutedTextColor};--sf-border:${settings.borderColor};--sf-radius:${settings.cardRadius}px;--sf-button-radius:${settings.buttonRadius}px;--sf-spacing:${settings.sectionSpacing}px;--sf-width:${settings.contentWidth}px;--sf-heading-font:${settings.headingFont};--sf-body-font:${settings.bodyFont};`}
>
  {preview && <div class="preview-banner">Draft preview</div>}
  <header class:list={['sf-header', editor && 'is-editor-section', selectedSectionId === headerSection?.id && 'is-editor-selected']} data-section-id={editor ? headerSection?.id : undefined} data-section-type={editor ? 'header' : undefined} data-section-label={editor ? headerSection?.label : undefined} data-editor-region={editor ? 'header' : undefined} {...editable('header', 'header')}>
    <a class="sf-logo" href={homeHref}>{settings.logoText || store.name.slice(0, 2)}<span {...editable('storeNameDisplay')}>{settings.storeNameDisplay || store.name}</span></a>
    <nav>{nav.map((item) => link(item.href) && <a href={link(item.href)} data-editor-navigation-id={editor ? item.id : undefined} data-editor-navigation-area={editor ? 'mainMenu' : undefined} {...editable('navigationLabel', 'navigation', item.id)}>{item.label}</a>)}</nav>
    <div class="sf-actions"><a href={`${homeHref}/search`}>Search</a><a href={`${homeHref}/account`}>Account</a><a href={`${homeHref}/cart`}>Cart</a></div>
  </header>
  <main>
    {contentSections.map((section, sectionIndex) => (
      <section
        class:list={['sf-section', `sf-${section.type}`, section.settings.fullWidth === true && 'is-full-width', section.settings.imagePosition === 'left' && 'image-left', `heading-${String(section.settings.headingSize || 'default')}`, editor && 'is-editor-section', selectedSectionId === section.id && 'is-editor-selected']}
        data-section-id={section.id}
        data-section-index={sectionIndex}
        data-section-type={section.type}
        data-section-label={section.label}
        data-section-locked={section.settings.locked === true ? 'true' : 'false'}
        draggable={editor && section.settings.locked !== true}
        style={sectionStyle(section)}
      >
        {editor && <><button class="canvas-section-drag" type="button" data-section-drag-handle aria-label={`Drag ${section.label}`} title="Drag to reorder">Drag</button><div class="canvas-section-tag">{section.label}</div></>}
        {section.type === 'announcement' && <p class="sf-announcement" {...editable('text')}>{String(section.settings.text ?? 'Announcement')}</p>}
        {section.type === 'hero' && (
          <div class="sf-hero">
            <div class="sf-hero-copy">
              <p class="sf-eyebrow" {...editable('eyebrow')}>{String(section.settings.eyebrow ?? 'Featured')}</p>
              <h1 {...editable('heading')}>{String(section.settings.heading ?? 'Build your storefront')}</h1>
              <p {...editable('body', 'rich-text')}>{String(section.settings.body ?? 'Add your own text in the editor.')}</p>
              {section.blocks.filter((block) => block.visible).map((block) => block.type === 'button' && link(block.settings.href) && <a class="sf-button" href={link(block.settings.href)} {...editable('buttonLabel', 'button', block.id)}>{String(block.settings.label ?? 'Shop now')}</a>)}
            </div>
            <div class="sf-media" {...editable('imageAssetId', 'image')} data-editor-image-drop={editor ? 'true' : undefined}>
              {section.settings.imageAssetId ? <img src={assetHref(String(section.settings.imageAssetId))} alt={String(section.settings.imageAlt ?? '')} /> : editor ? <button type="button" class="canvas-empty-prompt" data-replace-image>Add image</button> : <span aria-hidden="true"></span>}
              {editor && <button class="canvas-resize-handle" type="button" data-resize-handle="mediaWidth" aria-label="Resize media column" title="Drag to resize media"></button>}
            </div>
          </div>
        )}
        {['featured_collection', 'product_grid', 'featured_product', 'category_grid', 'collection_list'].includes(section.type) && (
          <div {...editable('products', 'products')}>
            <h2 {...editable('heading')}>{String(section.settings.heading ?? section.label)}</h2>
            {section.type === 'category_grid' || section.type === 'collection_list' ? (() => {
              const categories = [...new Set(catalogue.map((product) => product.category).filter(Boolean))].slice(0, Number(section.settings.productCount ?? 6));
              return categories.length ? <div class="sf-products">{categories.map((category) => <a class="sf-product sf-category-card" href={`${homeHref}/collections/${encodeURIComponent(category.toLowerCase().replace(/[^a-z0-9]+/g, '-'))}`}><div class="sf-product-image"></div><h3>{category}</h3><p>Explore collection</p></a>)}</div> : <div class="sf-catalogue-empty"><p>No collections available yet.</p>{editor && <button type="button" data-open-tool="products">Add categories to products</button>}</div>;
            })() : (() => {
              const selectedIds = String(section.settings.productIds ?? '').split(',').filter(Boolean);
              const collection = String(section.settings.collection ?? '');
              const available = collection ? catalogue.filter((product) => product.category === collection) : catalogue;
              const products = (selectedIds.length ? selectedIds.map((id) => available.find((product) => product.id === id)).filter(Boolean) : available).slice(0, Number(section.settings.productCount ?? (section.type === 'featured_product' ? 1 : 4)));
              return products.length ? <div class="sf-products">{products.map((product) => <article class="sf-product">{product!.imageAssetId ? <img class="sf-product-image" src={assetHref(product!.imageAssetId)} alt={product!.name} loading="lazy" /> : <div class="sf-product-image sf-image-placeholder" aria-hidden="true"></div>}<h3><a href={`${homeHref}/products/${encodeURIComponent(product!.slug)}`}>{product!.name}</a></h3><p>£{(product!.pricePence / 100).toFixed(2)}</p></article>)}</div> : <div class="sf-catalogue-empty"><p>No products selected yet.</p>{editor && <button type="button" data-open-inspector="products">Select products</button>}</div>;
            })()}
          </div>
        )}
        {['image_with_text', 'rich_text', 'promo_banner', 'newsletter', 'contact_callout', 'custom_order_callout'].includes(section.type) && (
          <div class:list={['sf-copy', section.type === 'image_with_text' && 'has-image']}>
            {section.type === 'image_with_text' && <div class="sf-copy-media" {...editable('imageAssetId', 'image')} data-editor-image-drop={editor ? 'true' : undefined}>{section.settings.imageAssetId ? <img class="sf-copy-image" src={assetHref(String(section.settings.imageAssetId))} alt={String(section.settings.imageAlt ?? '')} /> : editor && <button type="button" class="canvas-empty-prompt" data-replace-image>Add image</button>}{editor && <button class="canvas-resize-handle" type="button" data-resize-handle="mediaWidth" aria-label="Resize media column" title="Drag to resize media"></button>}</div>}
            <div><h2 {...editable('heading')}>{String(section.settings.heading ?? section.label)}</h2><p {...editable('body', 'rich-text')}>{String(section.settings.body ?? 'Add merchant content and calls to action here.')}</p></div>
          </div>
        )}
        {['benefits', 'testimonials', 'faq', 'gallery', 'social_grid', 'logo_list', 'multi_column'].includes(section.type) && (
          <div>
            <h2 {...editable('heading')}>{String(section.settings.heading ?? section.label)}</h2>
            <div class="sf-columns">
              {(section.blocks.length ? section.blocks : [1, 2, 3]).map((block: any, index: number) => (
                <article class="sf-column"><h3>{typeof block === 'number' ? `Block ${index + 1}` : String(block.settings.heading ?? block.label)}</h3><p>{typeof block === 'number' ? 'Structured content block.' : String(block.settings.text ?? block.settings.quote ?? 'Structured content block.')}</p></article>
              ))}
            </div>
          </div>
        )}
        {['image_banner', 'video_banner', 'slideshow'].includes(section.type) && (
          <div class="sf-visual-banner" {...editable('imageAssetId', 'image')} data-editor-image-drop={editor ? 'true' : undefined} style={section.settings.imageAssetId ? `background-image:linear-gradient(90deg,rgba(10,18,35,.64),rgba(10,18,35,.08)),url(${assetHref(String(section.settings.imageAssetId))})` : undefined}><div><p class="sf-eyebrow" {...editable('eyebrow')}>{String(section.settings.eyebrow ?? 'Featured')}</p><h2 {...editable('heading')}>{String(section.settings.heading ?? section.label)}</h2><p {...editable('body', 'rich-text')}>{String(section.settings.body ?? '')}</p>{editor && !section.settings.imageAssetId && <button type="button" class="canvas-empty-prompt" data-replace-image>Add background image</button>}</div></div>
        )}
        {section.type === 'before_after' && <div><h2 {...editable('heading')}>{String(section.settings.heading ?? section.label)}</h2><div class="sf-before-after"><span>Before</span><span>After</span></div></div>}
        {['map_location', 'opening_hours'].includes(section.type) && <div class="sf-business-info"><div><p class="sf-eyebrow">Store information</p><h2 {...editable('heading')}>{String(section.settings.heading ?? section.label)}</h2><p {...editable('body', 'rich-text')}>{String(section.settings.body ?? 'Add the details customers need before they visit.')}</p></div><div class="sf-business-visual">{section.type === 'map_location' ? 'Map and directions' : 'Opening times'}</div></div>}
        {section.type === 'divider' && <hr class="sf-divider" />}
        {section.type === 'spacer' && <div class="sf-spacer" aria-hidden="true"></div>}
        {editor && <>
          <div class="canvas-quick-actions" role="toolbar" aria-label={`${section.label} actions`}>
            <button type="button" data-canvas-action="duplicate" title="Duplicate section">Duplicate</button>
            <button type="button" data-canvas-action="copy" title="Copy section">Copy</button>
            <button type="button" data-canvas-action="visibility" title={section.visible ? 'Hide section' : 'Show section'}>Hide</button>
          </div>
          <button class="canvas-insert-section" type="button" data-insert-after={section.id} aria-label={`Add section after ${section.label}`}>Add section</button>
          <button class="canvas-spacing-handle is-top" type="button" data-spacing-handle="paddingTop" aria-label="Adjust top spacing"></button>
          <button class="canvas-spacing-handle is-bottom" type="button" data-spacing-handle="paddingBottom" aria-label="Adjust bottom spacing"></button>
        </>}
      </section>
    ))}
  </main>
  <footer class:list={['sf-footer', editor && 'is-editor-section', selectedSectionId === footerSection?.id && 'is-editor-selected']} data-section-id={editor ? footerSection?.id : undefined} data-section-type={editor ? 'footer' : undefined} data-section-label={editor ? footerSection?.label : undefined} data-editor-region={editor ? 'footer' : undefined} {...editable('footer', 'footer')}>
    <strong {...editable('storeNameDisplay')}>{settings.storeNameDisplay || store.name}</strong>
    <nav>{footer.map((item) => link(item.href) && <a href={link(item.href)} data-editor-navigation-id={editor ? item.id : undefined} data-editor-navigation-area={editor ? 'footerMenu' : undefined} {...editable('navigationLabel', 'navigation', item.id)}>{item.label}</a>)}</nav>
  </footer>
</div>
