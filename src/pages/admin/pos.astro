---
import MerchantAdminLayout from '../../layouts/MerchantAdminLayout.astro';
import { requireStoreMembership } from '../../lib/platform/auth';
const value = await requireStoreMembership(Astro);
if (!value) return Astro.redirect('/login');
const { store, user, membership } = value;
---
<MerchantAdminLayout title={`POS | ${store.name}`} store={store} user={user} membership={membership} heading="Point of sale" description="Prepare in-person selling for this store without loading legacy checkout screens.">
  <section class="grid">
    <div class="card"><h2>Setup status</h2><span class="badge warning">Not configured</span><p class="muted">POS hardware, registers and payment devices are not connected yet.</p></div>
    <div class="card"><h2>Locations</h2><p class="metric">0</p><p class="muted">Add selling locations when POS provisioning is implemented.</p></div>
    <div class="card"><h2>Registers</h2><p class="metric">0</p><p class="muted">Register setup is intentionally blank for new stores.</p></div>
  </section>
  <section class="card" style="margin-top:16px">
    <h2>POS foundations</h2>
    <ul class="checklist">
      <li><span class="dot"></span>Product availability by store</li>
      <li><span class="dot"></span>Staff POS permissions</li>
      <li><span class="dot"></span>Payment methods</li>
      <li><span class="dot"></span>Receipt settings</li>
    </ul>
  </section>
</MerchantAdminLayout>
