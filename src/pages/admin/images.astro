---
import AdminShell from '../../components/admin/AdminShell.astro';
import { createAdminCsrfToken, getAdminSession, isTrustedAdminOrigin, validateAdminCsrfToken } from '../../lib/adminAuth';
import { buildManagedImageView, MAX_IMAGE_UPLOAD_BYTES, saveManagedImage, type ManagedImageView } from '../../lib/imageStore';
import { managedImages } from '../../lib/managedImages';
import { getAdapterEnv } from '../../lib/runtimeEnv';
import { routes } from '../../lib/routes';
import '../../styles/global.css';

export const prerender = false;

let session = null;

try {
  session = await getAdminSession(Astro);
} catch {
  session = null;
}

if (!session) {
  return Astro.redirect(routes.adminLogin);
}

const env = getAdapterEnv(Astro);
const actionStatus = Astro.url.searchParams.get('status')?.trim() ?? '';
const savedImageId = Astro.url.searchParams.get('image')?.trim() ?? '';

if (Astro.request.method === 'POST') {
  if (!isTrustedAdminOrigin(Astro.request)) {
    return Astro.redirect(`${routes.adminImages}?status=csrf`);
  }

  const formData = await Astro.request.formData();
  const csrfToken = String(formData.get('csrf') ?? '');
  const imageId = String(formData.get('imageId') ?? '').trim();
  const file = formData.get('image');
  const validCsrf = await validateAdminCsrfToken(Astro, session, csrfToken);

  if (!validCsrf) {
    return Astro.redirect(`${routes.adminImages}?status=csrf`);
  }

  if (!(file instanceof File)) {
    return Astro.redirect(`${routes.adminImages}?status=invalid`);
  }

  try {
    await saveManagedImage(env, imageId, file);
    return Astro.redirect(`${routes.adminImages}?status=saved&image=${encodeURIComponent(imageId)}`);
  } catch (error) {
    return Astro.redirect(`${routes.adminImages}?status=${error instanceof Error && error.name === 'ImageValidationError' ? 'invalid' : 'storage'}&image=${encodeURIComponent(imageId)}`);
  }
}

const csrfToken = await createAdminCsrfToken(Astro, session);
let imageViews: ManagedImageView[] = [];
let loadError = '';

try {
  const views = await Promise.all(managedImages.map((image) => buildManagedImageView(env, image.id)));
  imageViews = views.filter((view): view is ManagedImageView => Boolean(view));
} catch {
  loadError = 'Live images could not be loaded. Existing public images are still being used.';
}

const maxUploadMb = Math.floor(MAX_IMAGE_UPLOAD_BYTES / 1024 / 1024);
const savedImage = imageViews.find((image) => image.id === savedImageId);
const bannerMessage = actionStatus === 'saved'
  ? `${savedImage?.label ?? 'Image'} saved. The public site now uses the replacement image.`
  : actionStatus === 'invalid'
    ? 'Choose a valid JPG, PNG, WebP, or AVIF image up to 4 MB.'
    : actionStatus === 'csrf'
      ? 'Your admin session could not verify that request. Please try again.'
      : actionStatus === 'storage'
        ? 'Image storage could not save that file. The existing live image was left unchanged.'
        : '';
const successStatus = actionStatus === 'saved';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Images | Admin Dashboard | Crumb Works</title>
  </head>

  <body class="font-body">
    <AdminShell
      activeNav="images"
      pageTitle="Images"
      pageSubtitle="Content"
      searchAction={routes.adminOrders}
      sessionEmail={session.email}
    >
      <Fragment slot="actions">
        <a
          href="/"
          class="rounded-2xl border border-black/8 bg-white px-4 py-2.5 text-sm font-semibold text-[#202223] shadow-sm transition hover:bg-[#fafafa]"
        >
          View site
        </a>
      </Fragment>

      {bannerMessage && (
        <div class:list={[
          'mb-4 rounded-[22px] border px-5 py-4 text-sm font-semibold shadow-[0_10px_30px_rgba(0,0,0,0.04)]',
          successStatus ? 'border-[#b8e6cc] bg-[#ecfff4] text-[#0f6b3f]' : 'border-[#f2b8b5] bg-[#fff0f0] text-[#a12018]',
        ]}>
          {bannerMessage}
        </div>
      )}

      {loadError && (
        <div class="mb-4 rounded-[22px] border border-[#f0d18a] bg-[#fff8e8] px-5 py-4 text-sm font-medium text-[#7a4d00] shadow-[0_10px_30px_rgba(0,0,0,0.04)]">
          {loadError}
        </div>
      )}

      <section class="rounded-[26px] border border-black/6 bg-white shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
        <div class="border-b border-black/6 px-5 py-5 md:px-6">
          <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="text-sm font-semibold text-[#6d7175]">Live-site images</p>
              <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#202223]">Replace existing images safely</h2>
            </div>
            <p class="text-sm text-[#6d7175]">JPG, PNG, WebP, or AVIF. Max {maxUploadMb} MB.</p>
          </div>
        </div>

        <div class="divide-y divide-black/6">
          {imageViews.map((image) => (
            <form method="POST" enctype="multipart/form-data" class="grid gap-5 p-5 md:grid-cols-[260px_minmax(0,1fr)_260px] md:p-6" data-image-form>
              <input type="hidden" name="csrf" value={csrfToken} />
              <input type="hidden" name="imageId" value={image.id} />

              <div>
                <p class="text-base font-semibold text-[#202223]">{image.label}</p>
                <p class="mt-1 text-sm leading-6 text-[#6d7175]">{image.usage}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  <span class="rounded-full bg-[#f1f1f1] px-3 py-1 text-xs font-semibold text-[#5f6368]">
                    {image.hasReplacement ? 'CMS replacement active' : 'Using fallback'}
                  </span>
                  {image.updatedAt && (
                    <span class="rounded-full bg-[#e8f5ef] px-3 py-1 text-xs font-semibold text-[#0f6b3f]">
                      Saved
                    </span>
                  )}
                </div>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <p class="mb-2 text-xs font-bold uppercase tracking-[0.14em] text-[#6d7175]">Current live image</p>
                  <div class="overflow-hidden rounded-[18px] border border-black/8 bg-[#f7f7f7]">
                    <img src={image.currentSrc} alt={image.alt} class="aspect-[4/3] w-full object-cover" loading="lazy" />
                  </div>
                  <p class="mt-2 truncate text-xs text-[#6d7175]">{image.hasReplacement ? image.originalName : image.fallbackSrc}</p>
                </div>

                <div>
                  <p class="mb-2 text-xs font-bold uppercase tracking-[0.14em] text-[#6d7175]">Replacement preview</p>
                  <div class="overflow-hidden rounded-[18px] border border-dashed border-black/16 bg-[#fbfbfb]">
                    <img src="" alt="" class="hidden aspect-[4/3] w-full object-cover" data-replacement-preview />
                    <div class="flex aspect-[4/3] items-center justify-center px-5 text-center text-sm font-medium leading-6 text-[#8a9096]" data-empty-preview>
                      Choose an image to preview it here before saving.
                    </div>
                  </div>
                  <p class="mt-2 truncate text-xs text-[#6d7175]" data-file-name>No replacement selected</p>
                </div>
              </div>

              <div class="flex flex-col justify-end gap-3">
                <label class="block">
                  <span class="mb-2 block text-xs font-bold uppercase tracking-[0.14em] text-[#6d7175]">Upload replacement</span>
                  <input
                    type="file"
                    name="image"
                    accept="image/jpeg,image/png,image/webp,image/avif"
                    class="block w-full rounded-[16px] border border-black/8 bg-white px-3 py-3 text-sm text-[#202223] file:mr-3 file:rounded-[12px] file:border-0 file:bg-[#f1f1f1] file:px-3 file:py-2 file:text-sm file:font-semibold file:text-[#202223]"
                    data-image-input
                    required
                  />
                </label>
                <button type="submit" class="h-11 rounded-[14px] bg-[#1d1d1d] px-4 text-sm font-semibold text-white transition hover:bg-black">
                  Save replacement
                </button>
                <p class="text-xs leading-5 text-[#6d7175]">Selecting a file only changes this preview. The public site changes after save.</p>
              </div>
            </form>
          ))}
        </div>
      </section>

      <script is:inline nonce={Astro.locals.cspNonce}>
        document.querySelectorAll('[data-image-form]').forEach((form) => {
          const input = form.querySelector('[data-image-input]');
          const preview = form.querySelector('[data-replacement-preview]');
          const emptyPreview = form.querySelector('[data-empty-preview]');
          const fileName = form.querySelector('[data-file-name]');
          let previewUrl = '';

          input?.addEventListener('change', () => {
            if (previewUrl) {
              URL.revokeObjectURL(previewUrl);
              previewUrl = '';
            }

            const file = input instanceof HTMLInputElement ? input.files?.[0] : null;

            if (!file) {
              preview?.classList.add('hidden');
              emptyPreview?.classList.remove('hidden');
              if (fileName) fileName.textContent = 'No replacement selected';
              return;
            }

            previewUrl = URL.createObjectURL(file);

            if (preview instanceof HTMLImageElement) {
              preview.src = previewUrl;
              preview.alt = file.name;
              preview.classList.remove('hidden');
            }

            emptyPreview?.classList.add('hidden');

            if (fileName) {
              fileName.textContent = file.name;
            }
          });
        });
      </script>
    </AdminShell>
  </body>
</html>
