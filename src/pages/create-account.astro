---
import PlatformLayout from '../layouts/PlatformLayout.astro';
import { registerMerchant } from '../lib/platform/store';
import { startSession } from '../lib/platform/auth';
let error = '';
if (Astro.request.method === 'POST') { const f=await Astro.request.formData(); const password=String(f.get('password')??''); if(password!==String(f.get('confirmPassword')??'')) error='Passwords do not match.'; else try { const result=await registerMerchant({firstName:String(f.get('firstName')??''),lastName:String(f.get('lastName')??''),businessName:String(f.get('businessName')??''),email:String(f.get('email')??''),phone:String(f.get('phone')??''),password,slug:String(f.get('slug')??''),category:String(f.get('category')??''),address:String(f.get('address')??'')},Astro); return new Response(null,{status:303,headers:{Location:'/admin/onboarding','Set-Cookie':await startSession({userId:result.user.id,role:'store_owner',storeId:result.store.id},Astro)}}); } catch { error='We couldn’t finish setting up your store. No duplicate account has been created. Please try again.'; } }
---
<PlatformLayout title="Create account | White Label"><main class="auth"><form class="panel stack" method="post"><div class="brand">White Label</div><div><h1>Create your workspace</h1><p class="muted">Start with a blank, private store administration area.</p></div>{error && <p class="error">{error}</p>}<div class="grid"><label class="field">First name<input name="firstName" required /></label><label class="field">Last name<input name="lastName" required /></label></div><label class="field">Business name<input name="businessName" required /></label><label class="field">Business email<input name="email" type="email" required /></label><label class="field">Phone<input name="phone" required /></label><label class="field">Preferred store slug<input name="slug" required pattern="[A-Za-z0-9-]{3,}" /></label><label class="field">Business category<input name="category" required /></label><label class="field">Operating location<textarea name="address" required></textarea></label><label class="field">Password<input name="password" type="password" minlength="12" required /></label><label class="field">Confirm password<input name="confirmPassword" type="password" minlength="12" required /></label><label class="field"><span><input name="terms" type="checkbox" required /> I agree to the platform terms.</span></label><button>Create account</button><a class="muted" href="/login">Already have an account?</a></form></main></PlatformLayout>
