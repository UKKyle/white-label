---
import AdminShell from '../../components/admin/AdminShell.astro';
import { createAdminCsrfToken, getAdminSession, isTrustedAdminOrigin, validateAdminCsrfToken } from '../../lib/adminAuth';
import { getAvailabilityRecord, saveUnavailableDates, isPlainDateString } from '../../lib/availabilityStore';
import { getAdapterEnv } from '../../lib/runtimeEnv';
import { routes } from '../../lib/routes';
import '../../styles/global.css';

export const prerender = false;

let session = null;

try {
  session = await getAdminSession(Astro);
} catch {
  session = null;
}

if (!session) {
  return Astro.redirect(routes.adminLogin);
}

const env = getAdapterEnv(Astro);
const actionStatus = Astro.url.searchParams.get('status')?.trim() ?? '';

if (Astro.request.method === 'POST') {
  if (!isTrustedAdminOrigin(Astro.request)) {
    return Astro.redirect(`${routes.adminAvailability}?status=csrf`);
  }

  const formData = await Astro.request.formData();
  const csrfToken = String(formData.get('csrf') ?? '');
  const validCsrf = await validateAdminCsrfToken(Astro, session, csrfToken);

  if (!validCsrf) {
    return Astro.redirect(`${routes.adminAvailability}?status=csrf`);
  }

  const input = String(formData.get('unavailableDates') ?? '[]');

  try {
    const parsed = JSON.parse(input);
    const unavailableDates = Array.isArray(parsed)
      ? parsed.filter((value): value is string => isPlainDateString(value))
      : [];

    await saveUnavailableDates(env, unavailableDates);
    return Astro.redirect(`${routes.adminAvailability}?status=saved`);
  } catch {
    return Astro.redirect(`${routes.adminAvailability}?status=invalid`);
  }
}

let unavailableDates: string[] = [];
let updatedAt = '';
let loadError = '';

try {
  const record = await getAvailabilityRecord(env);
  unavailableDates = record.unavailableDates;
  updatedAt = record.updatedAt;
} catch {
  loadError = 'Availability dates could not be loaded. You can still refresh the page, but storage must be reachable before dates can be edited safely.';
}

const csrfToken = await createAdminCsrfToken(Astro, session);
const message = actionStatus === 'saved'
  ? 'Availability saved. Public date selectors now use the updated unavailable dates.'
  : actionStatus === 'csrf'
    ? 'Security check failed. Please try again.'
    : actionStatus === 'invalid'
      ? 'Availability data could not be saved. Please try again.'
      : '';
const successStatus = actionStatus === 'saved';
const lastUpdated = updatedAt
  ? new Intl.DateTimeFormat('en-GB', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    }).format(new Date(updatedAt))
  : 'No saved availability changes yet';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Availability | Admin Dashboard | Crumb Works</title>
  </head>

  <body class="font-body">
    <AdminShell
      activeNav="availability"
      pageTitle="Availability"
      pageSubtitle="Unavailable date management"
      searchAction={routes.adminAvailability}
      sessionEmail={session.email}
    >
      <Fragment slot="actions">
        <a
          href="/contact"
          class="rounded-2xl border border-black/8 bg-white px-4 py-2.5 text-sm font-semibold text-[#202223] shadow-sm transition hover:bg-[#fafafa]"
        >
          View contact form
        </a>
      </Fragment>

      {message && (
        <div class:list={[
          'mb-4 rounded-[22px] border px-5 py-4 text-sm font-semibold shadow-[0_10px_30px_rgba(0,0,0,0.04)]',
          successStatus ? 'border-[#b8e6cc] bg-[#ecfff4] text-[#0f6b3f]' : 'border-[#f2b8b5] bg-[#fff0f0] text-[#a12018]',
        ]}>
          {message}
        </div>
      )}

      {loadError && (
        <div class="mb-4 rounded-[22px] border border-[#f0d18a] bg-[#fff8e8] px-5 py-4 text-sm font-medium text-[#7a4d00] shadow-[0_10px_30px_rgba(0,0,0,0.04)]">
          {loadError}
        </div>
      )}

      <form method="POST" class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_320px]">
        <input type="hidden" name="csrf" value={csrfToken} />

        <section class="rounded-[26px] border border-black/6 bg-white shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
          <div class="border-b border-black/6 px-5 py-5 md:px-6">
            <p class="text-sm font-semibold text-[#6d7175]">Calendar</p>
            <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#202223]">Mark dates as unavailable</h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-[#6d7175]">
              Click any date to toggle it unavailable. Customers will not be able to choose unavailable dates on the cart and enquiry forms once you save.
            </p>
          </div>

          <div class="p-5 md:p-6">
            <div
              class="availability-calendar"
              data-availability-calendar
              data-unavailable-dates={JSON.stringify(unavailableDates)}
            >
              <input type="hidden" name="unavailableDates" value={JSON.stringify(unavailableDates)} data-availability-input />
              <div class="availability-calendar__header">
                <button type="button" class="availability-calendar__nav" aria-label="Previous month" data-availability-prev>&larr;</button>
                <div>
                  <p class="availability-calendar__kicker">Calendar month</p>
                  <p class="availability-calendar__month" data-availability-month></p>
                </div>
                <button type="button" class="availability-calendar__nav" aria-label="Next month" data-availability-next>&rarr;</button>
              </div>
              <div class="availability-calendar__weekday-row" aria-hidden="true">
                <span>Mon</span>
                <span>Tue</span>
                <span>Wed</span>
                <span>Thu</span>
                <span>Fri</span>
                <span>Sat</span>
                <span>Sun</span>
              </div>
              <div class="availability-calendar__grid" data-availability-grid></div>
            </div>
          </div>
        </section>

        <aside class="space-y-5">
          <section class="rounded-[26px] border border-black/6 bg-white p-5 shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
            <p class="text-sm font-semibold text-[#6d7175]">Current selection</p>
            <p class="mt-2 text-3xl font-semibold tracking-tight text-[#202223]" data-availability-count>
              {unavailableDates.length === 1 ? '1 unavailable date' : `${unavailableDates.length} unavailable dates`}
            </p>
            <p class="mt-2 text-xs leading-5 text-[#6d7175]">
              Save after making changes so public date pickers refresh to match this calendar.
            </p>
          </section>

          <section class="sticky top-5 rounded-[26px] border border-black/6 bg-white p-5 shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
            <p class="text-sm font-semibold text-[#202223]">Save availability</p>
            <p class="mt-1 text-xs text-[#6d7175]">{lastUpdated}</p>
            <div class="mt-5 grid gap-3">
              <button type="submit" class="h-11 rounded-[14px] bg-[#1d1d1d] px-4 text-sm font-semibold text-white transition hover:bg-black">
                Save availability
              </button>
              <a href={routes.adminAvailability} class="flex h-11 items-center justify-center rounded-[14px] border border-black/10 bg-white px-4 text-sm font-semibold text-[#202223] transition hover:bg-[#f7f7f7]">
                Reset view
              </a>
            </div>
          </section>
        </aside>
      </form>

      <script type="module" src="/scripts/availability-ui.js"></script>
    </AdminShell>
  </body>
</html>
