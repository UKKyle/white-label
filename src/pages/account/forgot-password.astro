---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { sendPasswordResetEmail } from '../../lib/customerAccountEmails';
import { createAccountToken, getAccountByEmail } from '../../lib/customerAccountAuth';
import { getAdapterEnv } from '../../lib/runtimeEnv';
import { routes } from '../../lib/routes';
import { checkRateLimit, requestKey } from '../../security/rate-limit';
import { sanitizeEmail } from '../../security/sanitize';

export const prerender = false;

let message = '';
let error = '';

if (Astro.request.method === 'POST') {
  const email = sanitizeEmail((await Astro.request.formData()).get('email'));
  const emailAttemptKey = `${Astro.url.pathname}:email:${email || 'blank'}`;

  if (!checkRateLimit(requestKey(Astro.request), 3, 60_000) || !checkRateLimit(emailAttemptKey, 3, 15 * 60_000)) {
    error = 'Please wait a moment before trying again.';
  } else {
    const env = getAdapterEnv(Astro);
    const account = await getAccountByEmail(env, email);
    if (account?.status === 'active' && account.emailVerified) {
      const token = await createAccountToken(env, account.id, 'reset');
      await sendPasswordResetEmail(env, Astro.url, account.email, token).catch(() => undefined);
    }
    message = 'If an account exists for that email, we will send a password reset link shortly.';
  }
}
---

<Layout title="Forgot Password | The Crumb Works" description="Reset your The Crumb Works account password.">
  <PageHero align="center" title="Forgot Password" />
  <section class="warm-stage px-3 pb-18 pt-4 md:px-4">
    <div class="mx-auto max-w-xl">
      <form method="post" class="premium-form-card space-y-4">
        {message && <p class="rounded-[12px] border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">{message}</p>}
        {error && <p class="rounded-[12px] border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">{error}</p>}
        <label class="premium-field"><span>Email</span><input class="input-shell" name="email" type="email" required /></label>
        <button class="w-full rounded-[10px] bg-[var(--brand-ink)] px-6 py-3 text-sm font-semibold text-white" type="submit">Send reset link</button>
        <p class="text-center text-sm"><a class="font-semibold text-[var(--brand-purple)]" href={routes.accountSignIn}>Back to sign in</a></p>
      </form>
    </div>
  </section>
</Layout>
