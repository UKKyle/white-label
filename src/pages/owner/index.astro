---
import OwnerAdminLayout from '../../layouts/OwnerAdminLayout.astro';
import { requirePlatformOwner } from '../../lib/platform/auth';
import { listAuditLogs, listPlatformUsers, listStores } from '../../lib/platform/store';
const owner = await requirePlatformOwner(Astro);
if (!owner) return Astro.redirect('/owner/login');
const stores = await listStores(Astro);
const users = await listPlatformUsers(Astro);
const audits = await listAuditLogs(Astro, 5);
const active = stores.filter((s) => ['active', 'trial'].includes(s.status)).length;
const pastDue = stores.filter((s) => ['payment_due', 'past_due'].includes(s.billingStatus)).length;
const suspended = stores.filter((s) => s.status === 'suspended').length;
---
<OwnerAdminLayout title="Owner overview | White Label" heading="Overview" description="Platform-wide store health and recent activity.">
  <section class="grid">
    <div class="card"><p class="muted">Total stores</p><p class="metric">{stores.length}</p></div>
    <div class="card"><p class="muted">Active or trial</p><p class="metric">{active}</p></div>
    <div class="card"><p class="muted">Past due</p><p class="metric">{pastDue}</p></div>
    <div class="card"><p class="muted">Suspended</p><p class="metric">{suspended}</p></div>
    <div class="card"><p class="muted">Merchants</p><p class="metric">{users.length}</p></div>
  </section>
  <section class="two-col" style="margin-top:16px">
    <div class="card">
      <h2>Stores requiring attention</h2>
      {stores.filter((s) => s.status !== 'active' && s.status !== 'trial').length ? (
        <ul class="checklist">{stores.filter((s) => s.status !== 'active' && s.status !== 'trial').map((store) => <li><span class="dot"></span><a href={`/owner/stores/${store.id}`}>{store.name}</a> {store.status}</li>)}</ul>
      ) : <p class="muted">No stores currently require attention.</p>}
    </div>
    <div class="card">
      <h2>Recent activity</h2>
      {audits.length ? <ul class="checklist">{audits.map((event) => <li><span class="dot done"></span>{event.action} <span class="muted">{new Date(event.createdAt).toLocaleString('en-GB')}</span></li>)}</ul> : <p class="muted">No audit events recorded yet.</p>}
    </div>
  </section>
</OwnerAdminLayout>
