{
  "name": "new-website",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check:safety": "node scripts/check-prohibited-identifiers.mjs",
    "validate:env": "node scripts/validate-runtime-env.mjs",
    "guard:deploy": "node scripts/require-white-label-confirmation.mjs && node scripts/check-prohibited-identifiers.mjs",
    "build": "npm run check:safety && astro build && node scripts/patch-cloudflare-entry.mjs",
    "check": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run guard:deploy && npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.3",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
