---
import PlatformLayout from './PlatformLayout.astro';
import { isActivePath, ownerNavigation } from '../lib/platform/navigation';

const { title = 'Owner admin | White Label', heading = 'Platform overview', description = '' } = Astro.props as {
  title?: string;
  heading?: string;
  description?: string;
};
const pathname = Astro.url.pathname;
---
<PlatformLayout title={title}>
  <div class="dashboard-shell owner-shell">
    <aside class="dashboard-sidebar owner-sidebar" aria-label="Owner navigation">
      <div class="sidebar-brand">
        <span class="brand-mark">WL</span>
        <span>
          <strong>White Label</strong>
          <small>Platform owner</small>
        </span>
      </div>
      <nav class="sidebar-nav">
        {ownerNavigation.map((item) => (
          <a href={item.href} class:list={['sidebar-link', isActivePath(pathname, item.href) && 'is-active']}>{item.label}</a>
        ))}
      </nav>
      <a class="sidebar-link sidebar-signout" href="/admin/logout">Sign out</a>
    </aside>
    <main class="dashboard-main">
      <header class="dashboard-header">
        <div>
          <p class="eyebrow">Platform control</p>
          <h1>{heading}</h1>
          {description && <p class="muted">{description}</p>}
        </div>
        <span class="status">Owner access</span>
      </header>
      <slot />
    </main>
  </div>
</PlatformLayout>
