---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCustomerSession } from '../../lib/customerAccountAuth';
import { formatPrice } from '../../lib/format';
import { getLoyaltyBalance, listLoyaltyLedger } from '../../lib/loyalty';
import { getAdapterEnv } from '../../lib/runtimeEnv';

export const prerender = false;

const session = await getCustomerSession(Astro);
if (!session?.account.emailVerified) return Astro.redirect(routes.accountSignIn);

const env = getAdapterEnv(Astro);
const balance = await getLoyaltyBalance(env, session.account.id);
const entries = await listLoyaltyLedger(env, session.account.id, 50);
const dateFormatter = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---

<Layout title="Loyalty Points | The Crumb Works" description="View your The Crumb Works Loyalty Points balance and activity.">
  <PageHero align="center" title="Loyalty Points" />
  <section class="warm-stage px-3 pb-18 pt-4 md:px-4">
    <div class="mx-auto max-w-4xl space-y-5">
      <div class="premium-form-card">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--brand-ink-soft)]">Current balance</p>
        <div class="mt-3 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-4xl font-semibold text-[var(--brand-ink)]">{balance.points} points</p>
            <p class="mt-1 text-sm text-[var(--brand-ink-soft)]">Worth {formatPrice(balance.pence / 100)}</p>
          </div>
          <a href="/loyalty" class="inline-flex rounded-[10px] border border-[#f4bfd2] px-5 py-3 text-sm font-semibold text-[var(--brand-purple)]">How points work</a>
        </div>
      </div>

      <section class="premium-form-card">
        <h2 class="text-lg font-semibold text-[var(--brand-ink)]">Activity</h2>
        {entries.length ? (
          <div class="mt-4 divide-y divide-[#f8d8e4]">
            {entries.map((entry) => (
              <div class="grid gap-2 py-4 text-sm sm:grid-cols-[1fr_auto]">
                <div>
                  <p class="font-semibold text-[var(--brand-ink)]">{entry.description}</p>
                  <p class="mt-1 text-[var(--brand-ink-soft)]">
                    {dateFormatter.format(new Date(entry.createdAt))}
                    {entry.orderNumber ? ` · Order #${entry.orderNumber}` : ''}
                  </p>
                </div>
                <p class:list={['font-semibold', entry.points >= 0 ? 'text-emerald-700' : 'text-rose-700']}>
                  {entry.points >= 0 ? '+' : ''}{entry.points} points · {entry.pence >= 0 ? '+' : ''}{formatPrice(entry.pence / 100)}
                </p>
              </div>
            ))}
          </div>
        ) : (
          <p class="mt-4 text-sm leading-7 text-[var(--brand-ink-soft)]">Your Loyalty Points activity will appear here after eligible paid orders.</p>
        )}
      </section>
    </div>
  </section>
</Layout>
