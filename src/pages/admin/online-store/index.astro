---
import MerchantAdminLayout from '../../../layouts/MerchantAdminLayout.astro';
import Subnav from '../../../components/platform/Subnav.astro';
import { requireStoreMembership } from '../../../lib/platform/auth';
import { merchantOnlineStoreNavigation } from '../../../lib/platform/navigation';
const value = await requireStoreMembership(Astro);
if (!value) return Astro.redirect('/login');
const { store, user, membership } = value;
---
<MerchantAdminLayout title={`Online Store | ${store.name}`} store={store} user={user} membership={membership} heading="Online Store" description="Manage the storefront experience for this merchant.">
  <Subnav items={merchantOnlineStoreNavigation} />
  <section class="grid">
    <div class="card"><h2>Publishing status</h2><span class="badge warning">Draft</span><p class="muted">This store has not published a storefront configuration yet.</p></div>
    <div class="card"><h2>Template</h2><span class="badge">Studio foundation</span><p class="muted">Template selection will remain store-scoped.</p></div>
    <div class="card"><h2>Domain</h2><span class="badge">Not connected</span><p class="muted">Configure the domain workflow under settings.</p></div>
  </section>
  <section class="card" style="margin-top:16px">
    <h2>Storefront setup</h2>
    <div class="grid">
      <a class="button secondary" href="/admin/online-store/pages">Manage pages</a>
      <a class="button secondary" href="/admin/online-store/navigation">Manage navigation</a>
      <a class="button secondary" href="/admin/online-store/branding">Manage branding</a>
      <a class="button" href="/admin/settings/domains">Domains</a>
    </div>
  </section>
</MerchantAdminLayout>
