---
import AdminShell from '../../../components/admin/AdminShell.astro';
import { createAdminCsrfToken, getAdminSession, isTrustedAdminOrigin, validateAdminCsrfToken } from '../../../lib/adminAuth';
import { acceptOrderAndSendEmail, resendAcceptedOrderEmail, resendReceivedOrderEmail } from '../../../lib/orderEmails';
import { formatPrice } from '../../../lib/format';
import {
  adminStatusTone,
  formatFulfillmentLabel,
  formatOrderAdminStatusLabel,
  formatPaymentLabel,
  formatPaymentMethodLabel,
  formatSourceLabel,
  fulfillmentTone,
  manuallySetOrderFulfillmentStatus,
  paymentTone,
  sourceTone,
  syncOrderWithSumUp,
  updateAdminOrderFields,
} from '../../../lib/orderService';
import { getOrderByReference, type OrderRecord } from '../../../lib/orderStore';
import { getAdapterEnv } from '../../../lib/runtimeEnv';
import { routes } from '../../../lib/routes';
import { sanitizeText } from '../../../security/sanitize';
import '../../../styles/global.css';

export const prerender = false;

const reference = sanitizeText(Astro.params.reference).slice(0, 160);
const actionStatus = Astro.url.searchParams.get('status')?.trim() ?? '';

let session = null;

try {
  session = await getAdminSession(Astro);
} catch {
  session = null;
}

if (!session) {
  return Astro.redirect(routes.adminLogin);
}

const env = getAdapterEnv(Astro);

function detailHref(status?: string) {
  const url = routes.adminOrderDetail(reference);
  return status ? `${url}?status=${encodeURIComponent(status)}` : url;
}

if (Astro.request.method === 'POST') {
  if (!isTrustedAdminOrigin(Astro.request)) {
    return Astro.redirect(detailHref('csrf'));
  }

  const formData = await Astro.request.formData();
  const csrfToken = String(formData.get('csrf') ?? '');
  const action = String(formData.get('action') ?? '').trim();
  const validCsrf = await validateAdminCsrfToken(Astro, session, csrfToken);

  if (!validCsrf) {
    return Astro.redirect(detailHref('csrf'));
  }

  if (action === 'save-details') {
    const orderStatus = String(formData.get('orderStatus') ?? '').trim().toUpperCase();
    const adminNotes = sanitizeText(formData.get('adminNotes')).slice(0, 1200);

    if (!['NEW', 'ACCEPTED', 'IN_PROGRESS', 'COMPLETED', 'CANCELLED', 'ON_HOLD'].includes(orderStatus)) {
      return Astro.redirect(detailHref('invalid'));
    }

    let updated = null;

    try {
      updated = await updateAdminOrderFields(env, reference, {
        orderStatus: orderStatus as 'NEW' | 'ACCEPTED' | 'IN_PROGRESS' | 'COMPLETED' | 'CANCELLED' | 'ON_HOLD',
        adminNotes,
      });
    } catch {
      return Astro.redirect(detailHref('storage'));
    }

    return Astro.redirect(detailHref(updated ? 'saved' : 'missing'));
  }

  if (action === 'toggle-fulfillment') {
    const fulfillmentStatus = String(formData.get('fulfillmentStatus') ?? '').trim().toUpperCase();

    if (!['FULFILLED', 'UNFULFILLED'].includes(fulfillmentStatus)) {
      return Astro.redirect(detailHref('invalid'));
    }

    let updated = null;

    try {
      updated = await manuallySetOrderFulfillmentStatus(env, reference, fulfillmentStatus as 'FULFILLED' | 'UNFULFILLED');
    } catch {
      return Astro.redirect(detailHref('storage'));
    }

    return Astro.redirect(detailHref(updated ? (fulfillmentStatus === 'FULFILLED' ? 'fulfilled' : 'reopened') : 'missing'));
  }

  if (action === 'accept-order') {
    try {
      const result = await acceptOrderAndSendEmail(env, reference);

      if (result.error === 'missing') {
        return Astro.redirect(detailHref('missing'));
      }

      return Astro.redirect(detailHref(result.emailSent ? 'accepted' : 'accepted-email-failed'));
    } catch {
      return Astro.redirect(detailHref('storage'));
    }
  }

  if (action === 'resend-received-email') {
    try {
      const result = await resendReceivedOrderEmail(env, reference);

      if (!result.order) {
        return Astro.redirect(detailHref('missing'));
      }

      return Astro.redirect(detailHref(result.sent ? 'received-resent' : 'received-resend-failed'));
    } catch {
      return Astro.redirect(detailHref('storage'));
    }
  }

  if (action === 'resend-accepted-email') {
    try {
      const result = await resendAcceptedOrderEmail(env, reference);

      if (result.error === 'missing') {
        return Astro.redirect(detailHref('missing'));
      }

      return Astro.redirect(detailHref(result.emailSent ? 'accepted-resent' : 'accepted-resend-failed'));
    } catch {
      return Astro.redirect(detailHref('storage'));
    }
  }

  return Astro.redirect(detailHref('invalid'));
}

let order: OrderRecord | null = null;

try {
  order = await getOrderByReference(env, reference);

  if (order?.sumup?.checkoutId) {
    order = await syncOrderWithSumUp(env, order);
  }
} catch {
  return Astro.redirect(`${routes.adminOrders}?status=storage`);
}

if (!order) {
  return Astro.redirect(`${routes.adminOrders}?status=missing`);
}

const csrfToken = await createAdminCsrfToken(Astro, session);
const bannerMessage = actionStatus === 'saved'
  ? 'Order details saved.'
  : actionStatus === 'accepted'
    ? 'Order accepted and customer confirmation email sent.'
    : actionStatus === 'received-resent'
      ? 'Received email resent to the customer.'
    : actionStatus === 'accepted-resent'
      ? 'Accepted email resent to the customer.'
    : actionStatus === 'accepted-email-failed'
      ? 'Order accepted, but the customer confirmation email could not be sent. Please contact the customer manually.'
    : actionStatus === 'received-resend-failed'
      ? 'The received email resend failed. Check the email event details below.'
    : actionStatus === 'accepted-resend-failed'
      ? 'The accepted email resend failed. Check the email event details below.'
  : actionStatus === 'fulfilled'
    ? 'Order marked fulfilled.'
    : actionStatus === 'reopened'
      ? 'Order moved back to unfulfilled.'
      : actionStatus === 'invalid'
        ? 'That admin action was invalid.'
        : actionStatus === 'csrf'
          ? 'Your admin session could not verify that request. Please try again.'
          : actionStatus === 'storage'
            ? 'Order storage could not complete that admin action. Please try again after storage is reachable.'
          : actionStatus === 'missing'
            ? 'Order could not be found.'
            : '';

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
});

function formatOrderDate(value: string) {
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? value : dateFormatter.format(date);
}

const emailTimelineEvents = [
  {
    key: 'received',
    title: 'Order received email',
    sentAt: order.receivedEmailSentAt,
    failedAt: order.receivedEmailFailedAt,
    error: order.receivedEmailError,
    action: 'resend-received-email',
    actionLabel: order.receivedEmailSentAt ? 'Resend email' : 'Send now',
  },
  {
    key: 'accepted',
    title: 'Order accepted email',
    sentAt: order.acceptedEmailSentAt,
    failedAt: order.acceptedEmailFailedAt,
    error: order.acceptedEmailError,
    action: 'resend-accepted-email',
    actionLabel: order.acceptedEmailSentAt ? 'Resend email' : 'Send now',
  },
].filter((event) => event.key !== 'accepted' || order.acceptedAt || order.orderStatus === 'ACCEPTED');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order #{order.orderNumber} | Admin Dashboard | Crumb Works</title>
  </head>

  <body class="font-body">
    <AdminShell
      activeNav="orders"
      pageTitle={`Order #${order.orderNumber}`}
      pageSubtitle="Orders"
      searchAction={routes.adminOrders}
      searchQuery=""
      sessionEmail={session.email}
    >
      <Fragment slot="actions">
        <a
          href={routes.adminOrders}
          class="rounded-2xl border border-black/8 bg-white px-4 py-2.5 text-sm font-semibold text-[#202223] shadow-sm transition hover:bg-[#fafafa]"
        >
          Back to orders
        </a>
      </Fragment>

      {bannerMessage && (
        <div class="mb-4 rounded-[22px] border border-black/8 bg-white px-5 py-4 text-sm font-medium text-[#202223] shadow-[0_10px_30px_rgba(0,0,0,0.04)]">
          {bannerMessage}
        </div>
      )}

      <section class="grid gap-5 xl:grid-cols-[minmax(0,1.25fr)_380px]">
        <div class="space-y-5">
          <article class="rounded-[26px] border border-black/6 bg-white p-6 shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#8a9096]">{order.reference}</p>
                <h2 class="mt-2 text-[2rem] font-semibold tracking-tight text-[#202223]">Order #{order.orderNumber}</h2>
                <p class="mt-2 text-sm text-[#6d7175]">Created {formatOrderDate(order.createdAt)}</p>
              </div>
              <div class="flex flex-wrap gap-2">
                <span class:list={['inline-flex rounded-full px-3 py-1 text-sm font-semibold ring-1 ring-inset', paymentTone(order.paymentStatus)]}>
                  {formatPaymentLabel(order.paymentStatus)}
                </span>
                <span class:list={['inline-flex rounded-full px-3 py-1 text-sm font-semibold ring-1 ring-inset', fulfillmentTone(order.fulfillmentStatus)]}>
                  {formatFulfillmentLabel(order.fulfillmentStatus)}
                </span>
                <span class:list={['inline-flex rounded-full px-3 py-1 text-sm font-semibold ring-1 ring-inset', adminStatusTone(order.orderStatus)]}>
                  {formatOrderAdminStatusLabel(order.orderStatus)}
                </span>
                <span class:list={['inline-flex rounded-full px-3 py-1 text-sm font-semibold ring-1 ring-inset', sourceTone(order.source)]}>
                  {formatSourceLabel(order.source)}
                </span>
              </div>
            </div>

            <div class="mt-6 grid gap-4 md:grid-cols-3">
              <div class="rounded-[22px] bg-[#f7f7f7] p-4">
                <p class="text-sm font-medium text-[#6d7175]">Total</p>
                <p class="mt-2 text-2xl font-semibold text-[#202223]">{formatPrice(order.totalPence / 100)}</p>
                {order.subtotalPence != null && <p class="mt-1 text-sm text-[#6d7175]">Subtotal {formatPrice(order.subtotalPence / 100)}</p>}
              </div>
              <div class="rounded-[22px] bg-[#f7f7f7] p-4">
                <p class="text-sm font-medium text-[#6d7175]">Payment method</p>
                <p class="mt-2 text-xl font-semibold text-[#202223]">{formatPaymentMethodLabel(order.paymentMethod)}</p>
                {order.paidAt && <p class="mt-1 text-sm text-[#6d7175]">Paid {formatOrderDate(order.paidAt)}</p>}
              </div>
              <div class="rounded-[22px] bg-[#f7f7f7] p-4">
                <p class="text-sm font-medium text-[#6d7175]">Items</p>
                <p class="mt-2 text-xl font-semibold text-[#202223]">{order.items.reduce((sum, item) => sum + item.quantity, 0)}</p>
                <p class="mt-1 text-sm text-[#6d7175]">{order.currency}</p>
              </div>
            </div>

            {order.discount && (
              <div class="mt-4 rounded-[22px] border border-[#d7e5ff] bg-[#f3f7ff] p-4">
                <p class="text-sm font-semibold text-[#174ea6]">Signup discount</p>
                <div class="mt-3 grid gap-3 text-sm md:grid-cols-2">
                  <p class="text-[#4c4f52]">Original subtotal <strong class="text-[#202223]">{formatPrice((order.subtotalPence ?? order.totalPence + order.discount.amountPence) / 100)}</strong></p>
                  <p class="text-[#4c4f52]">Code <strong class="text-[#202223]">{order.discount.code}</strong></p>
                  <p class="text-[#4c4f52]">Discount <strong class="text-[#202223]">{order.discount.percent}% ({formatPrice(order.discount.amountPence / 100)})</strong></p>
                  <p class="text-[#4c4f52]">Minimum subtotal <strong class="text-[#202223]">{formatPrice(order.discount.minimumSubtotalPence / 100)}</strong></p>
                  <p class="text-[#4c4f52]">Final total paid <strong class="text-[#202223]">{formatPrice(order.totalPence / 100)}</strong></p>
                </div>
              </div>
            )}
            {order.loyalty?.redeemedPence && (
              <div class="mt-4 rounded-[22px] border border-[#f4c8d9] bg-[#fff8fb] p-4">
                <p class="text-sm font-semibold text-[var(--brand-purple)]">Loyalty Points</p>
                <div class="mt-3 grid gap-3 text-sm md:grid-cols-2">
                  <p class="text-[#4c4f52]">Redeemed <strong class="text-[#202223]">{order.loyalty.redeemedPoints ?? order.loyalty.redeemedPence} points ({formatPrice(order.loyalty.redeemedPence / 100)})</strong></p>
                  <p class="text-[#4c4f52]">Final charged amount <strong class="text-[#202223]">{formatPrice(order.totalPence / 100)}</strong></p>
                </div>
              </div>
            )}
          </article>

          <article class="rounded-[26px] border border-black/6 bg-white p-6 shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
            <h3 class="text-lg font-semibold text-[#202223]">Items</h3>
            <div class="mt-4 space-y-3">
              {order.items.map((item) => (
                <div class="flex items-start justify-between gap-4 rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                  <div>
                    <p class="font-semibold text-[#202223]">{item.quantity}x {item.name}</p>
                    <p class="mt-1 text-sm text-[#6d7175]">
                      {[item.category, item.flavour, item.servingSize].filter(Boolean).join(' · ') || 'Standard line item'}
                    </p>
                  </div>
                  <div class="text-right">
                    <p class="font-semibold text-[#202223]">{formatPrice(item.lineTotalPence / 100)}</p>
                    <p class="mt-1 text-sm text-[#6d7175]">{formatPrice(item.unitPricePence / 100)} each</p>
                  </div>
                </div>
              ))}
            </div>
          </article>

          <article class="rounded-[26px] border border-black/6 bg-white p-6 shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
            <div class="flex items-center justify-between gap-3">
              <h3 class="text-lg font-semibold text-[#202223]">Timeline</h3>
              {order.externalSourceId && <p class="text-sm text-[#6d7175]">External ID: {order.externalSourceId}</p>}
            </div>
            <div class="mt-5 space-y-3">
              {emailTimelineEvents.map((event) => (
                <div class="rounded-[20px] border border-black/6 bg-[#fbfbfb] px-4 py-4">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div class="space-y-2">
                      <div>
                        <p class="font-semibold text-[#202223]">{event.title}</p>
                        <p class="mt-1 text-sm text-[#6d7175]">
                          {event.sentAt
                            ? `Sent ${formatOrderDate(event.sentAt)}`
                            : event.failedAt
                              ? `Last failed ${formatOrderDate(event.failedAt)}`
                              : 'Not sent yet'}
                        </p>
                      </div>
                      {event.error && (
                        <p class="rounded-2xl bg-[#fff1f1] px-3 py-2 text-sm text-[#8f2b2b]">
                          {event.error}
                        </p>
                      )}
                    </div>
                    <form method="POST" class="shrink-0">
                      <input type="hidden" name="csrf" value={csrfToken} />
                      <input type="hidden" name="action" value={event.action} />
                      <button type="submit" class="inline-flex h-10 items-center rounded-2xl border border-black/8 bg-white px-4 text-sm font-semibold text-[#202223] transition hover:bg-[#f7f7f7]">
                        {event.actionLabel}
                      </button>
                    </form>
                  </div>
                </div>
              ))}
              {order.timeline.map((entry) => (
                <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      <p class="font-semibold text-[#202223]">{entry.label}</p>
                      {entry.status && <p class="mt-1 text-sm text-[#6d7175]">{entry.status}</p>}
                    </div>
                    <p class="text-sm text-[#6d7175]">{formatOrderDate(entry.at)}</p>
                  </div>
                </div>
              ))}
            </div>
          </article>
        </div>

        <div class="space-y-5">
          <article class="rounded-[26px] border border-black/6 bg-white p-6 shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
            <h3 class="text-lg font-semibold text-[#202223]">Customer</h3>
            <dl class="mt-4 space-y-3 text-sm">
              <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                <dt class="font-medium text-[#6d7175]">Name</dt>
                <dd class="mt-1 text-base text-[#202223]">{order.customer.name || 'Walk-in customer'}</dd>
              </div>
              <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                <dt class="font-medium text-[#6d7175]">Email</dt>
                <dd class="mt-1 text-base text-[#202223]">{order.customer.email || 'Not provided'}</dd>
              </div>
              <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                <dt class="font-medium text-[#6d7175]">Phone</dt>
                <dd class="mt-1 text-base text-[#202223]">{order.customer.phone || 'Not provided'}</dd>
              </div>
              <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                <dt class="font-medium text-[#6d7175]">Customer message</dt>
                <dd class="mt-1 text-base text-[#202223]">{order.customerMessage || order.customer.notes || 'None recorded'}</dd>
              </div>
            </dl>
          </article>

          <article class="rounded-[26px] border border-black/6 bg-white p-6 shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
            <h3 class="text-lg font-semibold text-[#202223]">Source & payment</h3>
            <dl class="mt-4 space-y-3 text-sm">
              <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                <dt class="font-medium text-[#6d7175]">Source</dt>
                <dd class="mt-1 text-base text-[#202223]">{formatSourceLabel(order.source)}</dd>
              </div>
              <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                <dt class="font-medium text-[#6d7175]">Payment method</dt>
                <dd class="mt-1 text-base text-[#202223]">{formatPaymentMethodLabel(order.paymentMethod)}</dd>
              </div>
              <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                <dt class="font-medium text-[#6d7175]">Payment status</dt>
                <dd class="mt-1 text-base text-[#202223]">{formatPaymentLabel(order.paymentStatus)}</dd>
              </div>
              {order.sumup?.checkoutId && (
                <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                  <dt class="font-medium text-[#6d7175]">SumUp checkout</dt>
                  <dd class="mt-1 text-base text-[#202223]">{order.sumup.checkoutId}</dd>
                </div>
              )}
              {order.pos && (
                <>
                  <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                    <dt class="font-medium text-[#6d7175]">POS user</dt>
                    <dd class="mt-1 text-base text-[#202223]">{order.pos.userName || 'Not provided'}</dd>
                  </div>
                  <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                    <dt class="font-medium text-[#6d7175]">POS device</dt>
                    <dd class="mt-1 text-base text-[#202223]">{order.pos.deviceId || 'Not provided'}</dd>
                  </div>
                  <div class="rounded-[20px] bg-[#f7f7f7] px-4 py-4">
                    <dt class="font-medium text-[#6d7175]">POS location</dt>
                    <dd class="mt-1 text-base text-[#202223]">{order.pos.location || 'Not provided'}</dd>
                  </div>
                </>
              )}
            </dl>
          </article>

          <article class="rounded-[26px] border border-black/6 bg-white p-6 shadow-[0_18px_44px_rgba(0,0,0,0.05)]">
            <h3 class="text-lg font-semibold text-[#202223]">Admin controls</h3>
            <form method="POST" class="mt-4 space-y-4">
              <input type="hidden" name="csrf" value={csrfToken} />
              <input type="hidden" name="action" value="save-details" />
              <label class="block">
                <span class="text-sm font-medium text-[#6d7175]">Order status</span>
                <select name="orderStatus" class="mt-2 h-12 w-full rounded-[18px] border border-black/8 bg-[#f7f7f7] px-4 text-[#202223] focus:outline-none">
                  {(['NEW', 'ACCEPTED', 'IN_PROGRESS', 'COMPLETED', 'CANCELLED', 'ON_HOLD'] as const).map((status) => (
                    <option value={status} selected={order.orderStatus === status}>
                      {formatOrderAdminStatusLabel(status)}
                    </option>
                  ))}
                </select>
              </label>

              <label class="block">
                <span class="text-sm font-medium text-[#6d7175]">Admin notes</span>
                <textarea
                  name="adminNotes"
                  rows="6"
                  class="mt-2 w-full rounded-[18px] border border-black/8 bg-[#f7f7f7] px-4 py-3 text-[#202223] focus:outline-none"
                  placeholder="Internal fulfilment notes, pickup details, or follow-up context."
                >{order.adminNotes ?? ''}</textarea>
              </label>

              <button type="submit" class="inline-flex h-11 items-center rounded-2xl border border-[#121212] bg-[#1d1d1d] px-4 text-sm font-semibold text-white transition hover:bg-black">
                Save changes
              </button>
            </form>

            <div class="mt-4 border-t border-black/6 pt-4">
              <p class="text-sm font-medium text-[#6d7175]">Customer email lifecycle is tracked in the timeline.</p>
              <dl class="mt-3 space-y-3 text-sm">
                <div class="rounded-[18px] bg-[#f7f7f7] px-4 py-3">
                  <dt class="font-medium text-[#6d7175]">Received email</dt>
                  <dd class="mt-1 text-[#202223]">{order.receivedEmailSentAt ? `Sent ${formatOrderDate(order.receivedEmailSentAt)}` : 'Not sent'}</dd>
                </div>
                <div class="rounded-[18px] bg-[#f7f7f7] px-4 py-3">
                  <dt class="font-medium text-[#6d7175]">Accepted email</dt>
                  <dd class="mt-1 text-[#202223]">{order.acceptedEmailSentAt ? `Sent ${formatOrderDate(order.acceptedEmailSentAt)}` : order.acceptedAt || order.orderStatus === 'ACCEPTED' ? 'Not sent' : 'Not available until accepted'}</dd>
                </div>
              </dl>
            </div>

            {!order.acceptedAt && order.orderStatus !== 'ACCEPTED' && order.orderStatus !== 'CANCELLED' && (
              <form method="POST" class="mt-4 border-t border-black/6 pt-4">
                <input type="hidden" name="csrf" value={csrfToken} />
                <input type="hidden" name="action" value="accept-order" />
                <button type="submit" class="inline-flex h-11 items-center rounded-2xl border border-[#121212] bg-[#1d1d1d] px-4 text-sm font-semibold text-white transition hover:bg-black">
                  Accept order
                </button>
              </form>
            )}

            <form method="POST" class="mt-4 border-t border-black/6 pt-4">
              <input type="hidden" name="csrf" value={csrfToken} />
              <input type="hidden" name="action" value="toggle-fulfillment" />
              <input type="hidden" name="fulfillmentStatus" value={order.fulfillmentStatus === 'FULFILLED' ? 'UNFULFILLED' : 'FULFILLED'} />
              <button type="submit" class="inline-flex h-11 items-center rounded-2xl border border-black/8 bg-white px-4 text-sm font-semibold text-[#202223] transition hover:bg-[#f7f7f7]">
                {order.fulfillmentStatus === 'FULFILLED' ? 'Mark unfulfilled' : 'Mark fulfilled'}
              </button>
            </form>
          </article>
        </div>
      </section>
    </AdminShell>
  </body>
</html>
