---
import AdminShell from '../../components/admin/AdminShell.astro';
import { createAdminCsrfToken, getAdminSession, isTrustedAdminOrigin, validateAdminCsrfToken } from '../../lib/adminAuth';
import { clearOrderRecords, listOrderRecords, type OrderRecord } from '../../lib/orderStore';
import { getAdapterEnv } from '../../lib/runtimeEnv';
import { routes } from '../../lib/routes';
import '../../styles/global.css';

export const prerender = false;

const CLEAR_CONFIRMATION = 'RESET ORDERS';

let session = null;

try {
  session = await getAdminSession(Astro);
} catch {
  session = null;
}

if (!session) {
  return Astro.redirect(routes.adminLogin);
}

const env = getAdapterEnv(Astro);
const actionStatus = Astro.url.searchParams.get('status')?.trim() ?? '';
const deletedOrders = Astro.url.searchParams.get('deleted')?.trim() ?? '';

if (Astro.request.method === 'POST') {
  if (!isTrustedAdminOrigin(Astro.request)) {
    return Astro.redirect(`${routes.adminSettings}?status=csrf`);
  }

  const formData = await Astro.request.formData();
  const csrfToken = String(formData.get('csrf') ?? '');
  const action = String(formData.get('action') ?? '').trim();
  const confirmation = String(formData.get('confirmation') ?? '').trim();
  const validCsrf = await validateAdminCsrfToken(Astro, session, csrfToken);

  if (!validCsrf) {
    return Astro.redirect(`${routes.adminSettings}?status=csrf`);
  }

  if (action !== 'clear-orders') {
    return Astro.redirect(`${routes.adminSettings}?status=invalid-action`);
  }

  if (confirmation !== CLEAR_CONFIRMATION) {
    return Astro.redirect(`${routes.adminSettings}?status=confirm`);
  }

  try {
    const result = await clearOrderRecords(env);
    return Astro.redirect(`${routes.adminSettings}?status=orders-cleared&deleted=${encodeURIComponent(String(result.deletedOrders))}`);
  } catch {
    return Astro.redirect(`${routes.adminSettings}?status=storage`);
  }
}

const csrfToken = await createAdminCsrfToken(Astro, session);
let orders: OrderRecord[] = [];
let ordersLoadError = '';

try {
  orders = await listOrderRecords(env);
} catch {
  ordersLoadError = 'Order storage could not be counted. The reset tool is still protected, but storage must be reachable before clearing orders.';
}

const onlineOrders = orders.filter((order) => order.source === 'online').length;
const posOrders = orders.filter((order) => order.source === 'pos').length;

function statusMessage(status: string) {
  const messages: Record<string, string> = {
    'orders-cleared': `Cleared ${deletedOrders || '0'} stored order${deletedOrders === '1' ? '' : 's'} from the CMS.`,
    confirm: `Type ${CLEAR_CONFIRMATION} to confirm clearing order data.`,
    csrf: 'Security check failed. Please try again.',
    storage: 'Order data could not be cleared. Check the Cloudflare KV binding and try again.',
    'invalid-action': 'The settings action was not recognised.',
  };

  return messages[status] ?? '';
}

const successStatus = actionStatus === 'orders-cleared';
const message = statusMessage(actionStatus);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Settings - Crumb Works Admin</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <AdminShell
      activeNav="settings"
      pageTitle="Settings"
      pageSubtitle="Admin maintenance"
      sessionEmail={session.email}
    >
      <div class="grid gap-5">
        <section class="rounded-[24px] border border-black/6 bg-white shadow-sm">
          <div class="border-b border-black/6 p-5 md:p-6">
            <p class="text-sm font-semibold text-[#6d7175]">Order data</p>
            <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#202223]">Testing reset</h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-[#6d7175]">
              Clear stored CMS order records after testing. This does not change SumUp hosted checkout settings, public storefront checkout, POS unlock security, POS products, or future order creation.
            </p>
          </div>

          {message && (
            <div class:list={[
              'm-5 rounded-[18px] border px-4 py-3 text-sm font-semibold md:m-6',
              successStatus ? 'border-[#b8e6cc] bg-[#ecfff4] text-[#0f6b3f]' : 'border-[#f2b8b5] bg-[#fff0f0] text-[#a12018]',
            ]}>
              {message}
            </div>
          )}

          {ordersLoadError && (
            <div class="m-5 rounded-[18px] border border-[#f0d18a] bg-[#fff8e8] px-4 py-3 text-sm font-semibold text-[#7a4d00] md:m-6">
              {ordersLoadError}
            </div>
          )}

          <div class="grid border-b border-black/6 bg-[#fbfbfc] md:grid-cols-3">
            <div class="border-b border-black/6 px-5 py-4 md:border-b-0 md:border-r">
              <p class="text-xs font-bold uppercase tracking-[0.14em] text-[#6d7175]">Stored orders</p>
              <p class="mt-2 text-xl font-semibold text-[#202223]">{orders.length}</p>
            </div>
            <div class="border-b border-black/6 px-5 py-4 md:border-b-0 md:border-r">
              <p class="text-xs font-bold uppercase tracking-[0.14em] text-[#6d7175]">Online checkout</p>
              <p class="mt-2 text-xl font-semibold text-[#202223]">{onlineOrders}</p>
            </div>
            <div class="px-5 py-4">
              <p class="text-xs font-bold uppercase tracking-[0.14em] text-[#6d7175]">POS orders</p>
              <p class="mt-2 text-xl font-semibold text-[#202223]">{posOrders}</p>
            </div>
          </div>

          <details class="group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-5 md:px-6">
              <span>
                <span class="block text-base font-semibold text-[#202223]">Clear all order data</span>
                <span class="mt-1 block text-sm text-[#6d7175]">Use this after testing to empty the CMS Orders workspace.</span>
              </span>
              <span class="rounded-[12px] border border-[#f2b8b5] bg-[#fff0f0] px-4 py-2.5 text-sm font-semibold text-[#a12018] transition group-open:bg-[#ffe1e1]">
                Clear orders
              </span>
            </summary>

            <form method="POST" class="grid gap-4 border-t border-black/6 bg-[#fffafa] px-5 py-5 md:grid-cols-[minmax(0,1fr)_auto] md:items-end md:px-6">
              <input type="hidden" name="csrf" value={csrfToken} />
              <input type="hidden" name="action" value="clear-orders" />
              <label class="block">
                <span class="text-sm font-semibold text-[#202223]">Type {CLEAR_CONFIRMATION} to confirm</span>
                <input
                  name="confirmation"
                  autocomplete="off"
                  class="mt-2 h-12 w-full rounded-[16px] border border-[#f2b8b5] bg-white px-4 text-sm font-semibold text-[#202223] outline-none focus:border-[#a12018]"
                  placeholder={CLEAR_CONFIRMATION}
                  required
                />
              </label>
              <button class="h-12 rounded-[16px] bg-[#a12018] px-5 text-sm font-semibold text-white transition hover:bg-[#7f1711]">
                Confirm clear
              </button>
            </form>
          </details>
        </section>
      </div>
    </AdminShell>
  </body>
</html>
