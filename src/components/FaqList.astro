---
import type { FaqItem } from '../types/shop';

interface Props {
  items: FaqItem[];
  variant?: 'default' | 'branded';
}

const { items, variant = 'default' } = Astro.props;
---

<div class="grid gap-4">
  {items.map((item) => (
    <details class:list={[
      'faq-item overflow-hidden p-0',
      variant === 'branded'
        ? 'rounded-[20px] border border-[#f3cad9] bg-white shadow-[0_12px_30px_rgba(36,29,66,0.08)] transition hover:-translate-y-0.5 hover:border-[var(--brand-pink)] hover:shadow-[0_16px_36px_rgba(36,29,66,0.12)]'
        : 'card-shell'
    ]} name="faq">
      <summary class:list={[
        'flex cursor-pointer list-none items-start justify-between gap-4 text-left marker:hidden',
        variant === 'branded'
          ? 'px-5 py-5 md:px-6 md:py-5.5'
          : 'px-5 py-5 text-base font-semibold text-[var(--brand-ink)]'
      ]}>
        <span class="flex min-w-0">
          <span class:list={[
            variant === 'branded'
              ? 'poster-title text-2xl leading-none text-[var(--brand-purple)] md:text-3xl'
              : ''
          ]}>{item.question}</span>
        </span>
        <span class:list={[
          'faq-item__icon shrink-0 text-[var(--brand-purple)]',
          variant === 'branded'
            ? 'flex h-9 w-9 items-center justify-center rounded-full border border-[#f4c8d9] bg-[#fff7fa] text-xl leading-none'
            : 'mt-0.5'
        ]} aria-hidden="true">+</span>
      </summary>
      <div class:list={[
        'border-t border-[rgba(77,24,191,0.08)]',
        variant === 'branded' ? 'mx-5 px-0 pb-5 pt-4 md:mx-6' : 'px-5 pb-5 pt-4'
      ]}>
        <p class="max-w-3xl text-sm leading-7 text-[var(--brand-ink-soft)] md:text-base">{item.answer}</p>
      </div>
    </details>
  ))}
</div>
