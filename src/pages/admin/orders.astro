---
import MerchantAdminLayout from '../../layouts/MerchantAdminLayout.astro';
import { requireStoreMembership } from '../../lib/platform/auth';
const value = await requireStoreMembership(Astro);
if (!value) return Astro.redirect('/login');
const { store, user, membership } = value;
---
<MerchantAdminLayout title={`Orders | ${store.name}`} store={store} user={user} membership={membership} heading="Orders" description="Manage orders for the active store only.">
  <section class="toolbar">
    <input class="input" type="search" placeholder="Search orders" aria-label="Search orders" style="max-width:320px" />
    <div class="split">
      <select class="input" aria-label="Order status"><option>All statuses</option><option>Open</option><option>Fulfilled</option><option>Cancelled</option></select>
      <select class="input" aria-label="Payment status"><option>All payments</option><option>Paid</option><option>Pending</option><option>Failed</option></select>
    </div>
  </section>
  <section class="table-wrap">
    <table>
      <thead><tr><th>Order</th><th>Customer</th><th>Fulfilment</th><th>Payment</th><th>Total</th><th>Date</th><th>Action</th></tr></thead>
      <tbody><tr><td colspan="7"><div class="empty">No store-scoped orders exist yet. Orders created through the future tenant storefront will appear here.</div></td></tr></tbody>
    </table>
  </section>
</MerchantAdminLayout>
